---
import Layout from "../layouts/Layout.astro";

export interface Props {
  code: string;
  title: string;
  message: string;
  description: string;
}

const { code, title, message, description } = Astro.props;
const pageTitle = `${code} — ${title.toLowerCase()}`;
---

<Layout title={pageTitle} description={description}>
  <div class="max-w-md mx-auto py-16 font-mono text-xs text-text leading-relaxed text-center" style="padding-top: 8rem; padding-bottom: 10rem;">
    <div class="text-6xl font-mono font-bold text-accent/20 select-none leading-none mb-6">
      {code}
    </div>
    <h1 class="text-sm font-semibold text-white mb-3 lowercase">
      {title}
    </h1>
    <p class="text-text-muted max-w-xs mx-auto leading-relaxed mb-8 lowercase">
      {message}
    </p>
    <div class="flex items-center justify-center gap-6 lowercase">
      <a
        href="/"
        class="text-accent hover:text-white underline"
      >
        [home]
      </a>
      <a
        href="/blog"
        class="text-accent hover:text-white underline"
      >
        [blog]
      </a>
    </div>
  </div>
</Layout>
