---
const themes = [
  { id: "midnight", name: "Midnight", icon: "moon" },
  { id: "rose", name: "Rose", icon: "heart" },
  { id: "ice", name: "Ice", icon: "snowflake" },
  { id: "blues", name: "Blues", icon: "droplet" },
];

const icons = {
  moon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>`,
  heart: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>`,
  snowflake: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="2" x2="22" y1="12" y2="12"/><line x1="12" x2="12" y1="2" y2="22"/><path d="m20 16-4-4 4-4"/><path d="m4 8 4 4-4 4"/><path d="m16 4-4 4-4-4"/><path d="m8 20 4-4 4 4"/></svg>`,
  droplet: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>`,
  palette: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>`,
};
---

<div class="relative" id="theme-switcher">
  <button
    id="theme-toggle"
    class="flex items-center justify-center p-2 rounded-full hover:bg-surface/50 text-secondary hover:text-primary transition-colors"
    aria-label="Switch theme"
  >
    <span set:html={icons.palette}></span>
  </button>

  <div
    id="theme-menu"
    class="absolute right-0 top-full mt-2 py-2 w-40 rounded-xl border border-border/80 bg-surface/95 backdrop-blur shadow-xl opacity-0 invisible transition-all duration-200 z-50"
  >
    {
      themes.map((theme) => (
        <button
          data-theme={theme.id}
          class="w-full px-4 py-2.5 text-left text-sm text-secondary hover:text-primary hover:bg-border/30 transition-colors flex items-center gap-3"
        >
          <span class="text-primary" set:html={icons[theme.icon]}></span>
          <span>{theme.name}</span>
        </button>
      ))
    }
  </div>
</div>

<script>
  const themes = ['midnight', 'rose', 'ice', 'blues'];
  const themeToggle = document.getElementById('theme-toggle');
  const themeMenu = document.getElementById('theme-menu');
  const themeSwitcher = document.getElementById('theme-switcher');

  // Load saved theme
  const savedTheme = localStorage.getItem('theme') || 'midnight';
  applyTheme(savedTheme);

  // Toggle menu
  themeToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = themeMenu?.classList.contains('opacity-100');
    if (isOpen) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  // Theme selection
  themeMenu?.querySelectorAll('[data-theme]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      const theme = (e.currentTarget as HTMLElement).dataset.theme;
      if (theme && themes.includes(theme)) {
        applyTheme(theme);
        localStorage.setItem('theme', theme);
        closeMenu();
      }
    });
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!themeSwitcher?.contains(e.target as Node)) {
      closeMenu();
    }
  });

  function openMenu() {
    themeMenu?.classList.remove('opacity-0', 'invisible');
    themeMenu?.classList.add('opacity-100', 'visible');
  }

  function closeMenu() {
    themeMenu?.classList.remove('opacity-100', 'visible');
    themeMenu?.classList.add('opacity-0', 'invisible');
  }

  function applyTheme(theme: string) {
    document.documentElement.classList.remove(
      'theme-midnight',
      'theme-rose',
      'theme-ice',
      'theme-blues'
    );
    
    if (theme === 'midnight') {
      document.documentElement.classList.add('dark', 'theme-midnight');
    } else {
      document.documentElement.classList.remove('dark');
      document.documentElement.classList.add(`theme-${theme}`);
    }
  }
</script>

<style>
  #theme-menu {
    margin-top: 0.5rem;
  }
</style>
