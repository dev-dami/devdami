---
import ThemeSwitcher from "./ThemeSwitcher.astro";
---

<nav class="sticky top-4 z-50 flex justify-center px-4" id="navbar">
  <div class="nav-content flex items-center gap-6 px-5 py-2.5 rounded-full border border-border/80 bg-bg/80 backdrop-blur-md shadow-lg shadow-black/20 transition-all duration-300 hover:border-accent/50 hover:bg-bg/95">
    <a href="/" class="flex items-center gap-3 group">
<img
  src="https://avatars.githubusercontent.com/u/141376183"
  alt="Damilare Osibanjo"
  class="w-8 h-8 rounded-full object-cover ring-2 ring-border/50 group-hover:ring-accent/50 transition-all duration-300"
  loading="lazy"
/>
      <span class="nav-title font-medium tracking-tight text-sm text-primary group-hover:text-accent transition-all duration-300 overflow-hidden whitespace-nowrap sm:block">
        Damilare Osibanjo
      </span>
    </a>
    
    <div class="flex items-center gap-1">
      <div class="nav-divider h-4 w-px bg-border/50 transition-all duration-300"></div>
      <a href="/projects" class="nav-link px-3 py-1.5 text-sm text-secondary hover:text-primary hover:bg-surface/50 rounded-full transition-all">Projects</a>
      <a href="/about" class="nav-link px-3 py-1.5 text-sm text-secondary hover:text-primary hover:bg-surface/50 rounded-full transition-all">About</a>
      <a href="/blog" class="nav-link px-3 py-1.5 text-sm text-secondary hover:text-primary hover:bg-surface/50 rounded-full transition-all">Blog</a>
      <div class="nav-divider h-4 w-px bg-border/50 transition-all duration-300"></div>
      <a href="https://github.com/dev-dami" target="_blank" class="nav-icon p-2 text-secondary hover:text-primary hover:bg-surface/50 rounded-full transition-all" aria-label="GitHub">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>
      <ThemeSwitcher />
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const navContent = navbar?.querySelector('.nav-content');
  const navTitle = navbar?.querySelector('.nav-title');
  const navDividers = navbar?.querySelectorAll('.nav-divider');
  const navLinks = navbar?.querySelectorAll('.nav-link');
  const navIcons = navbar?.querySelectorAll('.nav-icon');
  
  let lastScrollY = window.scrollY;
  let ticking = false;
  
  function updateNavbar() {
    const scrollY = window.scrollY;
    const isScrolled = scrollY > 50;
    const isScrollingDown = scrollY > lastScrollY;
    
    if (isScrollingDown && scrollY > 100) {
      // Shrink on scroll down
      navContent?.classList.add('nav-shrunk');
      navTitle?.classList.add('nav-title-hidden');
      navDividers?.forEach(div => div.classList.add('nav-divider-hidden'));
      navLinks?.forEach(link => link.classList.add('nav-link-hidden'));
    } else if (!isScrollingDown && scrollY < 100) {
      // Grow on scroll up or at top
      navContent?.classList.remove('nav-shrunk');
      navTitle?.classList.remove('nav-title-hidden');
      navDividers?.forEach(div => div.classList.remove('nav-divider-hidden'));
      navLinks?.forEach(link => link.classList.remove('nav-link-hidden'));
    }
    
    lastScrollY = scrollY;
    ticking = false;
  }
  
  function onScroll() {
    if (!ticking) {
      window.requestAnimationFrame(updateNavbar);
      ticking = true;
    }
  }
  
  window.addEventListener('scroll', onScroll, { passive: true });
</script>

<style>
  .nav-shrunk {
    padding-left: 0.75rem !important;
    padding-right: 0.75rem !important;
    padding-top: 0.375rem !important;
    padding-bottom: 0.375rem !important;
  }
  
  .nav-title-hidden {
    width: 0 !important;
    opacity: 0 !important;
    margin: 0 !important;
  }
  
  .nav-divider-hidden {
    width: 0 !important;
    opacity: 0 !important;
    padding: 0 !important;
  }
  
  .nav-link-hidden {
    padding-left: 0 !important;
    padding-right: 0 !important;
    opacity: 0 !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    pointer-events: none;
  }
</style>
