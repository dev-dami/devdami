<canvas id="hero-stars" aria-hidden="true"></canvas>

<script>
  import RealisticStarfield from "my-constellation-bg";

  const canvas = document.getElementById("hero-stars");
  if (canvas) {
    const starfield = new RealisticStarfield(canvas, {
      starCount: 200,
      backgroundColor: "#050505",
      enableMeteors: false,
      enableTwinkle: true,
      twinkleIntensity: 0.5,
      enableParallax: false,
      enableNebula: false,
      enableAurora: false,
      enableClusters: false,
      enablePulsate: true,
      enableClickEffect: false,
      enableTouch: false,
      enableInteraction: false,
      performanceMode: true,
    });

    // Every 7s, shuffle star positions so they disappear
    // and reappear somewhere else in the hero area
    setInterval(() => {
      const w = starfield.displayWidth;
      const h = starfield.displayHeight;
      if (!w || !h) return;
      starfield.stars.forEach((star) => {
        star.x = Math.random() * w;
        star.y = Math.random() * h;
      });
    }, 7000);
  }
</script>

<style>
  #hero-stars {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
  }
</style>
