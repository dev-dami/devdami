---
import Layout from "./Layout.astro";
import NewsletterSignup from "../components/NewsletterSignup.astro";
const { frontmatter, allPosts = [] } = Astro.props;

const date = frontmatter.date instanceof Date ? frontmatter.date : new Date(frontmatter.date);
const pageTitle = `${frontmatter.title} — damilare.code`;
const pageDescription = frontmatter.description || "technical article by damilare osibanjo on systems programming, compilers, and infrastructure";
const pageUrl = `https://devdami.varityweb.com/blog/${Astro.params.slug}`;
const ogParams = new URLSearchParams({ title: frontmatter.title });
if (frontmatter.tags?.length) {
  ogParams.set('tags', frontmatter.tags.slice(0, 4).join(','));
}
const pageImage = frontmatter.ogImage || `/api/og?${ogParams.toString()}`;
const readingTime = frontmatter.readingTime;

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: frontmatter.title,
  description: pageDescription,
  image: pageImage.startsWith('/') ? `https://devdami.varityweb.com${pageImage}` : pageImage,
  datePublished: frontmatter.date,
  author: {
    "@type": "Person",
    name: "Damilare Osibanjo",
    url: "https://devdami.varityweb.com"
  },
  publisher: {
    "@type": "Person",
    name: "Damilare Osibanjo",
    url: "https://devdami.varityweb.com",
    sameAs: [
      "https://github.com/dev-dami",
      "https://www.linkedin.com/in/damilare-osibanjo/"
    ]
  },
  keywords: frontmatter.tags,
  url: pageUrl
};

// Compute series info (prev/next within same series)
const seriesName = frontmatter.series?.name;
const seriesPosts = seriesName
  ? allPosts
      .filter((p: any) => p.data.series?.name === seriesName)
      .sort((a: any, b: any) => (a.data.series?.order ?? 0) - (b.data.series?.order ?? 0))
  : [];
const currentSeriesIndex = seriesPosts.findIndex((p: any) => p.slug === Astro.params.slug);
const prevInSeries = currentSeriesIndex > 0 ? seriesPosts[currentSeriesIndex - 1] : null;
const nextInSeries = currentSeriesIndex < seriesPosts.length - 1 ? seriesPosts[currentSeriesIndex + 1] : null;

// Compute related posts by shared tags (exclude current, max 3)
const relatedPosts = allPosts
  .filter((p: any) => p.slug !== Astro.params.slug)
  .map((p: any) => {
    const sharedTags = p.data.tags.filter((t: string) => frontmatter.tags.includes(t));
    return { post: p, score: sharedTags.length };
  })
  .filter((p: any) => p.score > 0)
  .sort((a: any, b: any) => b.score - a.score)
  .slice(0, 3)
  .map((p: any) => p.post);
---

<Layout title={pageTitle} description={pageDescription} canonical={pageUrl} image={pageImage} ogType="article">
  {/* JSON-LD Structured Data */}
  <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />

  <article class="mx-auto max-w-2xl py-16 font-mono text-xs text-text leading-relaxed px-4">
    <!-- Header -->
    <header class="mb-12 text-center">
      <a href="/blog" class="text-text-muted hover:text-white transition-colors block mb-4">&lt;- back to blog</a>
      <h1 class="text-base font-semibold text-white lowercase mb-4 leading-snug">
        {frontmatter.title}
      </h1>
      {frontmatter.series && (
        <div class="mb-3 text-[10px] text-accent/60 lowercase">
          // series: {frontmatter.series.name} · part {frontmatter.series.order}
        </div>
      )}
      <div class="flex items-center justify-center gap-3 text-[10px] text-text-muted lowercase">
        <time>{date.toDateString().toLowerCase()}</time>
        {readingTime && (
          <>
            <span>·</span>
            <span>{readingTime} min read</span>
          </>
        )}
        <span>·</span>
        <div class="flex flex-wrap gap-2">
          {frontmatter.tags.map((tag: string) => (
            <span>#{tag.toLowerCase()}</span>
          ))}
        </div>
      </div>
    </header>

    {/* Takeaways box */}
    {frontmatter.takeaways && (
      <aside class="tldr mb-10 p-4 border border-border/40 bg-surface/20 lowercase" itemscope itemtype="https://schema.org/FAQPage">
        <h3 class="text-[10px] font-semibold tracking-widest text-white uppercase font-mono mb-2">
          // key takeaways
        </h3>
        <ul class="text-xs text-text-muted leading-relaxed space-y-2">
          {frontmatter.takeaways.split('\n').filter((t: string) => t.trim()).map((item: string) => (
            <li class="flex items-start gap-2" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
              <span class="text-accent mt-0.5 flex-shrink-0">-</span>
              <span itemprop="name">{item.trim().replace(/^[-*•]\s*/, '')}</span>
            </li>
          ))}
        </ul>
      </aside>
    )}

    <!-- Content -->
    <div id="article-content" class="prose prose-invert max-w-none space-y-6 pb-12 overflow-x-hidden text-xs lowercase leading-relaxed text-text">
      <slot />
    </div>

    {/* Series navigation */}
    {seriesPosts.length > 1 && (
      <div class="mt-12 pt-6 border-t border-border/40 lowercase">
        <h3 class="text-[10px] font-semibold tracking-widest text-white uppercase font-mono mb-4">
          // series: {seriesName}
        </h3>
        <div class="flex justify-between gap-4 text-[10px] text-text-muted font-mono">
          {prevInSeries ? (
            <a href={`/blog/${prevInSeries.slug}`} class="hover:text-white">
              ← prev: {prevInSeries.data.title}
            </a>
          ) : <span />}
          {nextInSeries ? (
            <a href={`/blog/${nextInSeries.slug}`} class="hover:text-white">
              next: {nextInSeries.data.title} →
            </a>
          ) : <span />}
        </div>
      </div>
    )}

    {/* Related posts */}
    {relatedPosts.length > 0 && (
      <div class="mt-12 pt-6 border-t border-border/40 lowercase">
        <h3 class="text-[10px] font-semibold tracking-widest text-white uppercase font-mono mb-6">
          // related posts
        </h3>
        <div class="space-y-4">
          {relatedPosts.map((p: any) => {
            const relDate = p.data.date instanceof Date ? p.data.date : new Date(p.data.date);
            return (
              <a href={`/blog/${p.slug}`} class="group block">
                <span class="text-white group-hover:text-accent font-semibold underline block mb-1">
                  {p.data.title}
                </span>
                <p class="text-text-muted mt-0.5 mb-1 text-[11px] leading-relaxed">
                  {p.data.description}
                </p>
                <div class="text-[9px] text-text-muted font-mono">
                  {relDate.toDateString().toLowerCase()}
                </div>
              </a>
            );
          })}
        </div>
      </div>
    )}

    <!-- Newsletter signup -->
    <NewsletterSignup />

    <!-- Checklist CTA for build-experience post -->
    {Astro.params.slug === 'build-programming-experience-no-hire' && (
      <div class="mt-8 p-4 border border-border/40 bg-surface/20 lowercase">
        <p class="text-[11px] text-text leading-relaxed">
          <span class="text-accent font-semibold">→</span> get the printable checklist version of this guide —
          <a href="/checklist/build-experience" class="text-accent hover:underline font-medium ml-1">
            download the build experience checklist
          </a>
        </p>
      </div>
    )}
  </article>
</Layout>