---
import Layout from "./Layout.astro";
import NewsletterSignup from "../components/NewsletterSignup.astro";
const { frontmatter, allPosts = [] } = Astro.props;

const date = frontmatter.date instanceof Date ? frontmatter.date : new Date(frontmatter.date);
const pageTitle = `${frontmatter.title} - Damilare Osibanjo`;
const pageDescription = frontmatter.description || "Technical article by Damilare Osibanjo on systems programming, compilers, and infrastructure";
const pageUrl = `https://devdami.varityweb.com/blog/${Astro.params.slug}`;
const ogParams = new URLSearchParams({ title: frontmatter.title });
if (frontmatter.tags?.length) {
  ogParams.set('tags', frontmatter.tags.slice(0, 4).join(','));
}
const pageImage = frontmatter.ogImage || `/api/og?${ogParams.toString()}`;
const readingTime = frontmatter.readingTime;

// Compute series info (prev/next within same series)
const seriesName = frontmatter.series?.name;
const seriesPosts = seriesName
  ? allPosts
      .filter((p: any) => p.data.series?.name === seriesName)
      .sort((a: any, b: any) => (a.data.series?.order ?? 0) - (b.data.series?.order ?? 0))
  : [];
const currentSeriesIndex = seriesPosts.findIndex((p: any) => p.slug === Astro.params.slug);
const prevInSeries = currentSeriesIndex > 0 ? seriesPosts[currentSeriesIndex - 1] : null;
const nextInSeries = currentSeriesIndex < seriesPosts.length - 1 ? seriesPosts[currentSeriesIndex + 1] : null;

// Compute related posts by shared tags (exclude current, max 3)
const relatedPosts = allPosts
  .filter((p: any) => p.slug !== Astro.params.slug)
  .map((p: any) => {
    const sharedTags = p.data.tags.filter((t: string) => frontmatter.tags.includes(t));
    return { post: p, score: sharedTags.length };
  })
  .filter((p: any) => p.score > 0)
  .sort((a: any, b: any) => b.score - a.score)
  .slice(0, 3)
  .map((p: any) => p.post);
---

<Layout title={pageTitle} description={pageDescription} canonical={pageUrl} image={pageImage} ogType="article">

  {/* JSON-LD Structured Data */}
  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": frontmatter.title,
      "description": pageDescription,
      "image": pageImage.startsWith('/') ? `https://devdami.varityweb.com${pageImage}` : pageImage,
      "datePublished": frontmatter.date,
      "author": {
        "@type": "Person",
        "name": "Damilare Osibanjo",
        "url": "https://devdami.varityweb.com"
      },
      "publisher": {
        "@type": "Person",
        "name": "Damilare Osibanjo",
        "url": "https://devdami.varityweb.com",
        "sameAs": [
          "https://github.com/dev-dami",
          "https://www.linkedin.com/in/damilare-osibanjo/"
        ]
      },
      "keywords": frontmatter.tags,
      "url": pageUrl
    })}
  </script>

  <article class="mx-auto max-w-blog">
    <!-- Reading Progress Bar -->
    <div class="fixed bottom-0 left-0 w-full h-1 z-50 bg-surface/50 backdrop-blur">
      <div id="progress-bar" class="h-full bg-gradient-to-r from-accent to-accent-hover w-0 transition-all duration-100"></div>
    </div>

    <header class="mb-12 space-y-4">
      <h1 class="text-3xl md:text-4xl font-normal tracking-wide text-text-dark">
        {frontmatter.title}
      </h1>
      {frontmatter.series && (
        <div class="flex items-center gap-2">
          <span class="text-xs font-mono text-accent border border-accent/30 bg-accent/5 px-2 py-0.5 rounded">
            {frontmatter.series.name} • Part {frontmatter.series.order}
          </span>
        </div>
      )}
      <div class="flex items-center gap-3 text-sm">
        <time class="font-mono text-muted">{date.toDateString()}</time>
        {readingTime && (
          <>
            <span class="text-border">•</span>
            <span class="font-mono text-muted">{readingTime} min read</span>
          </>
        )}
        <span class="text-border">•</span>
        <div class="flex flex-wrap gap-2">
          {frontmatter.tags.map((tag: string) => (
            <span class="px-2 py-0.5 text-xs bg-surface border border-border rounded text-muted">
              {tag}
            </span>
          ))}
        </div>
      </div>
    </header>

    {/* Takeaways box */}
    {frontmatter.takeaways && (
      <aside class="tldr mb-10 p-4 md:p-6 border border-accent/30 bg-accent/5 rounded-lg" itemscope itemtype="https://schema.org/FAQPage">
        <h3 class="text-xs font-semibold tracking-widest text-accent uppercase font-mono mb-2">
          Key Takeaways
        </h3>
        <ul class="text-sm text-text leading-relaxed space-y-2">
          {frontmatter.takeaways.split('\n').filter((t: string) => t.trim()).map((item: string) => (
            <li class="flex items-start gap-2" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
              <span class="text-accent mt-1.5 flex-shrink-0">◆</span>
              <span itemprop="name">{item.trim().replace(/^[-*•]\s*/, '')}</span>
            </li>
          ))}
        </ul>
      </aside>
    )}

    <div id="article-content" class="prose prose-invert max-w-none space-y-6 pb-20">
      <slot />
    </div>

    {/* Series navigation */}
    {seriesPosts.length > 1 && (
      <div class="mt-16 pt-8 border-t border-border">
        <h3 class="text-sm font-semibold tracking-widest text-text-dark uppercase font-mono mb-4">
          <span class="text-accent opacity-60">//</span> {seriesName}
        </h3>
        <div class="flex flex-col sm:flex-row gap-3 justify-between">
          {prevInSeries ? (
            <a
              href={`/blog/${prevInSeries.slug}`}
              class="group flex-1 p-4 border border-border rounded-lg hover:border-accent/40 transition-all bg-surface/20"
            >
              <span class="text-xs text-muted/60 font-mono">← Previous</span>
              <span class="block mt-1 text-sm font-semibold text-text-dark group-hover:text-accent transition-colors line-clamp-2">
                {prevInSeries.data.title}
              </span>
            </a>
          ) : <div class="flex-1" />}
          {nextInSeries ? (
            <a
              href={`/blog/${nextInSeries.slug}`}
              class="group flex-1 p-4 border border-border rounded-lg hover:border-accent/40 transition-all bg-surface/20 text-right"
            >
              <span class="text-xs text-muted/60 font-mono">Next →</span>
              <span class="block mt-1 text-sm font-semibold text-text-dark group-hover:text-accent transition-colors line-clamp-2">
                {nextInSeries.data.title}
              </span>
            </a>
          ) : <div class="flex-1" />}
        </div>
      </div>
    )}

    {/* Related posts */}
    {relatedPosts.length > 0 && (
      <div class="mt-16 pt-8 border-t border-border">
        <h3 class="text-sm font-semibold tracking-widest text-text-dark uppercase font-mono mb-6">
          <span class="text-accent opacity-60">//</span> Related Posts
        </h3>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {relatedPosts.map((p: any) => {
            const relDate = p.data.date instanceof Date ? p.data.date : new Date(p.data.date);
            const relReadingTime = p.data.readingTime;
            return (
              <a
                href={`/blog/${p.slug}`}
                class="group block p-4 border border-border rounded-lg hover:border-accent/40 transition-all bg-surface/20"
              >
                <h4 class="text-sm font-semibold text-text-dark group-hover:text-accent transition-colors line-clamp-2">
                  {p.data.title}
                </h4>
                <p class="mt-1.5 text-xs text-muted line-clamp-2 leading-relaxed">
                  {p.data.description}
                </p>
                <div class="mt-2 flex items-center gap-2 text-xs text-muted/60 font-mono">
                  <time>{relDate.toDateString()}</time>
                  {relReadingTime && <><span>·</span><span>{relReadingTime} min</span></>}
                </div>
              </a>
            );
          })}
        </div>
      </div>
    )}

    <!-- Newsletter signup -->
    <NewsletterSignup />

    <!-- Checklist CTA for build-experience post -->
    {Astro.params.slug === 'build-programming-experience-no-hire' && (
      <div class="mt-6 p-4 md:p-6 border border-accent/30 bg-accent/5 rounded-lg">
        <p class="text-sm text-text leading-relaxed">
          <span class="text-accent font-semibold">→</span> Get the printable checklist version of this guide —
          <a
            href="/checklist/build-experience"
            class="text-accent hover:underline font-medium"
          >
            Download the Build Experience PDF
          </a>
        </p>
      </div>
    )}

    <!-- Back to top button -->
    <div class="fixed bottom-8 right-8 z-40">
      <a
       href="#top"
       class="flex items-center justify-center w-10 h-10 rounded-lg bg-surface border border-border text-muted hover:text-text-dark hover:border-accent/50 transition-all"
       aria-label="Back to top"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
        </svg>
      </a>
    </div>
  </article>
</Layout>