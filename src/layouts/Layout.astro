---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import Navbar from "../components/Navbar";
import CommandPalette from "../components/CommandPalette";
import "../styles/global.css";

const siteUrl = 'https://devdami.varityweb.com';
const siteName = 'Damilare Osibanjo';
const defaultDescription = '17 year old Systems & Software Programmer. Building distributed infrastructure, runtime tools, and developer experiences with TypeScript, Rust, and Go.';

const {
  title = 'Damilare Osibanjo - Systems & Software Programmer',
  description = defaultDescription,
  canonical = new URL(Astro.url.pathname, siteUrl).href,
  image = '/icon.png',
  ogType = 'website',
} = Astro.props;

const fullImage = image.startsWith('http') ? image : `${siteUrl}${image}`;

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Damilare Osibanjo",
  url: siteUrl,
  image: `${siteUrl}/icon.png`,
  sameAs: [
    "https://github.com/dev-dami",
    "https://www.linkedin.com/in/damilare-osibanjo/"
  ],
  jobTitle: "Systems & Software Programmer",
  description: defaultDescription,
  email: "mailto:dami@varityweb.com"
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Damilare Osibanjo" />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImage} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonical} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={fullImage} />
    
    <!-- Favicon -->
    <link rel="icon" href="/icon.png" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonical} />
    
    <!-- Preconnect to external fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" />
    
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Additional SEO -->
    <meta name="theme-color" content="#050505" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    
    <!-- Open Graph -->
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content={siteName} />
    <meta property="article:author" content="Damilare Osibanjo" />
    
    <!-- Twitter Enhanced -->
    <meta property="twitter:creator" content="@dev_dami" />
    
    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    
    <!-- Vercel Web Analytics -->
    <Analytics />
    
    <!-- Vercel Speed Insights -->
    <SpeedInsights />
  </head>
  <body class="min-h-screen bg-bg text-text font-body antialiased">
    <canvas id="starstreak-canvas" aria-hidden="true"></canvas>
    <div class="flex flex-col min-h-screen">
      <Navbar client:load />
      <main class="flex-1 mx-auto w-full max-w-content px-4 sm:px-6 pt-6 pb-12 md:px-8 md:pt-8 md:pb-16 lg:px-12">
        <slot />
      </main>
      <footer class="border-t border-border/50">
        <div class="mx-auto w-full max-w-content px-6 py-8 md:px-10 lg:px-16">
          <div class="flex items-center justify-between">
            <p class="text-sm text-muted">
              &copy; {new Date().getFullYear()} Damilare Osibanjo. Built with Astro.
            </p>
            <p class="text-xs text-muted hidden sm:block">
              Press <kbd class="px-1.5 py-0.5 bg-border/30 rounded mx-1">Ctrl</kbd> + <kbd class="px-1.5 py-0.5 bg-border/30 rounded mx-1">K</kbd> to search
            </p>
          </div>
        </div>
      </footer>
    </div>
    <CommandPalette client:load />

  <script>
    import RealisticStarfield from "my-constellation-bg";

    const canvas = document.getElementById("starstreak-canvas");

    if (canvas) {
      new RealisticStarfield(canvas, {
        starCount: 0,
        backgroundColor: "#050505",
        enableMeteors: true,
        meteorInterval: 10000,
        meteorAngle: 35,
        enableTwinkle: false,
        twinkleIntensity: 0,
        enableParallax: false,
        enableNebula: false,
        enableAurora: false,
        enableClusters: false,
        enablePulsate: false,
        enableClickEffect: false,
        enableTouch: false,
        enableInteraction: false,
        performanceMode: true,
      });
    }
  </script>
  </body>
</html>

<style is:global>
  @view-transition {
    navigation: auto;
  }

  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation: none;
    mix-blend-mode: normal;
  }

  #starstreak-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
  }

  .nav-shrunk {
    padding-left: 0.5rem !important;
    padding-right: 0.5rem !important;
    padding-top: 0.25rem !important;
    padding-bottom: 0.25rem !important;
    gap: 0.5rem !important;
  }

  .nav-shrunk .nav-avatar {
    width: 1.5rem !important;
    height: 1.5rem !important;
  }

  .nav-shrunk .nav-title {
    font-size: 0.75rem !important;
  }

  .nav-shrunk .nav-link {
    padding: 0.25rem 0.5rem !important;
    font-size: 0.6875rem !important;
  }

  .nav-shrunk .nav-github-icon {
    padding: 0.25rem !important;
  }

  .nav-shrunk .nav-github-icon svg {
    width: 0.875rem !important;
    height: 0.875rem !important;
  }

</style>
