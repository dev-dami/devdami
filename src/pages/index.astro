                </a>
              </div>
              <p class="text-xs text-white/70 leading-relaxed mb-2">{p.desc}</p>
              <div class="flex flex-wrap gap-1">
                {p.tags.map(t => <span class="px-1.5 py-px text-xs font-mono text-text-muted border border-border/70">{t}</span>)}
              </div>
            </div>
          </div>
          <a href={p.href} target="_blank" class="absolute inset-0" aria-label={`View ${p.name} on GitHub`}></a>
        </article>
      ))}

    </div>
