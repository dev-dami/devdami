  <script>
    // Rotating quotes typewriter animation
    const quotes = [
      '"Simplicity is the ultimate sophistication."',
      '"First, solve the problem. Then, write the code."',
      '"Code is like humor. When you have to explain it, it\'s bad."',
      '"Talk is cheap. Show me the code."',
      '"Programs must be written for people to read, and only incidentally for machines to execute."'
    ];
    
    let quoteIndex = 0;
    let charIndex = 0;
    let isDeleting = false;
    const quoteElement = document.querySelector('.animate-fade-slide');
    
    function type() {
      if (!quoteElement) return;

      const currentQuote = quotes[quoteIndex];

      if (isDeleting) {
        quoteElement.textContent = currentQuote.substring(0, charIndex - 1);
        charIndex--;
      } else {
        quoteElement.textContent = currentQuote.substring(0, charIndex + 1);
        charIndex++;
      }

      let typeSpeed = isDeleting ? 30 : 60;

      if (!isDeleting && charIndex === currentQuote.length) {
        isDeleting = true;
        typeSpeed = 3000; // Wait at the end of the quote
      } else if (isDeleting && charIndex === 0) {
        isDeleting = false;
        quoteIndex = (quoteIndex + 1) % quotes.length;
        typeSpeed = 500; // Wait before starting next quote
      }

      setTimeout(type, typeSpeed);
    }

    if (quoteElement) {
      // Remove the animation class since we are doing it via JS now
      quoteElement.classList.remove('animate-fade-slide');
      // Add a cursor effect
      quoteElement.classList.add('border-r-2', 'border-accent', 'pr-1');
      type();
    }
  </script>

