                {p.npm && <span class="px-1 py-px text-xs font-mono text-accent border border-accent/40 leading-none">npm</span>}
                <a href={p.href} target="_blank" class="p-0.5 text-text-muted hover:text-accent transition-all z-10 relative" aria-label="View on GitHub">
