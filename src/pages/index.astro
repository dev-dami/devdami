---
import Layout from "../layouts/Layout.astro";
import HeroStars from "../components/HeroStars.astro";
import ContactForm from "../components/ContactForm";
import { projects } from "../data/projects";
import { fetchUserStats, fetchCommitCount, computeYearsCoding } from "../utils/github";
export const prerender = true;

const userStats = await fetchUserStats("dev-dami");
const repoCount = userStats?.publicRepos ?? null;
const commitCount = await fetchCommitCount("dev-dami");
const yearsCoding = computeYearsCoding(2022);
---

<Layout>
  <!-- Main Center-Aligned minimal view -->
  <div class="flex flex-col items-center justify-center min-h-[70vh] py-16 text-center max-w-sm mx-auto font-mono">
    <!-- Bio header -->
    <header class="mb-12">
      <h1 class="text-xl font-medium text-white tracking-tight lowercase">
        damilare
      </h1>
      <p class="text-xs text-text-muted mt-1 lowercase">
        builds things
      </p>
    </header>

    <!-- Main Navigation List (theo/t3.gg style) -->
    <nav class="flex flex-col items-center gap-6 w-full mb-16 text-sm">
      <a href="#projects" class="text-text hover:text-white transition-colors duration-200 lowercase">
        dami.projects
      </a>
      <a href="/blog" class="text-text hover:text-white transition-colors duration-200 lowercase">
        dami.code (blog)
      </a>
      <a href="/uses" class="text-text hover:text-white transition-colors duration-200 lowercase">
        dami.uses
      </a>
      <a href="/about" class="text-text hover:text-white transition-colors duration-200 lowercase">
        dami.about
      </a>
      <a href="/wiki" class="text-text hover:text-white transition-colors duration-200 lowercase">
        dami.wiki
      </a>
      <a href="/resume" class="text-text hover:text-white transition-colors duration-200 lowercase">
        dami.resume
      </a>
    </nav>

    <!-- Footer links -->
    <footer class="w-full pt-8 border-t border-border/40 flex justify-center gap-6 text-xs text-text-muted">
      <a href="https://github.com/dev-dami" target="_blank" class="hover:text-white transition-colors duration-200 lowercase">
        gh
      </a>
      <a href="https://www.linkedin.com/in/damilare-osibanjo/" target="_blank" class="hover:text-white transition-colors duration-200 lowercase">
        linkedin
      </a>
      <a href="mailto:dami@varityweb.com" class="hover:text-white transition-colors duration-200 lowercase">
        email
      </a>
    </footer>
  </div>

  <!-- Smooth Projects & Contact sections positioned further below for deep scrolling if needed -->
  <div class="max-w-md mx-auto mt-24 pt-16 border-t border-border/20 font-mono" id="projects">
    <h2 class="text-xs text-text-muted uppercase tracking-widest mb-8 text-center">// selected work</h2>
    <div class="space-y-8">
      {projects.map(p => (
        <article class="group relative">
          <div class="flex items-baseline justify-between mb-1">
            <h3 class="text-sm font-semibold text-white group-hover:text-accent transition-colors">
              <a href={`/projects/${p.slug}`} class="hover:underline">{p.name}</a>
            </h3>
            <span class="text-[10px] text-text-muted">{p.number}</span>
          </div>
          <p class="text-xs text-text-muted leading-relaxed mb-2">{p.description}</p>
          <div class="flex flex-wrap gap-2">
            {p.tags.map(t => <span class="text-[9px] text-text-muted/60">#{t.toLowerCase()}</span>)}
          </div>
        </article>
      ))}
    </div>
  </div>

  <div class="max-w-md mx-auto mt-24 pt-16 border-t border-border/20 font-mono">
    <h2 class="text-xs text-text-muted uppercase tracking-widest mb-8 text-center">// connect</h2>
    <ContactForm client:load />
  </div>

  <script>
    // Rotating quotes typewriter animation
    const quotes = [
      '"Simplicity is the ultimate sophistication."',
      '"First, solve the problem. Then, write the code."',
      '"I use Arch, by the way."',
      '"Memory safety is nice, Memory discipline is nicer"',
      '"Code is like humor. When you have to explain it, it\'s bad."',
      '"Talk is cheap. Show me the code."',
      '"Programs must be written for people to read, and only incidentally for machines to execute."'
    ];

    let quoteIndex = 0;
    let charIndex = 0;
    let isDeleting = false;
    const quoteElement = document.getElementById('rotating-quote');

    function type() {
      if (!quoteElement) return;

      const currentQuote = quotes[quoteIndex];

      if (isDeleting) {
        quoteElement.textContent = currentQuote.substring(0, charIndex - 1);
        charIndex--;
      } else {
        quoteElement.textContent = currentQuote.substring(0, charIndex + 1);
        charIndex++;
      }

      let typeSpeed = isDeleting ? 30 : 60;

      if (!isDeleting && charIndex === currentQuote.length) {
        isDeleting = true;
        typeSpeed = 3000;
      } else if (isDeleting && charIndex === 0) {
        isDeleting = false;
        quoteIndex = (quoteIndex + 1) % quotes.length;
        typeSpeed = 500;
      }

      setTimeout(type, typeSpeed);
    }

    if (quoteElement) {
      quoteElement.classList.add('border-r-2', 'border-white', 'pr-1');
      type();
    }
  </script>
</Layout>
