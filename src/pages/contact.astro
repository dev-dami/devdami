---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm";
export const prerender = true;

const pageTitle = "dami.contact";
const pageDescription = "get in touch with damilare osibanjo — systems and software programmer.";
---

<Layout title={pageTitle} description={pageDescription}>
  <div class="max-w-sm mx-auto py-16 font-mono text-xs text-text leading-relaxed">
    <header class="mb-12 text-center">
      <a href="/" class="text-text-muted hover:text-white transition-colors block mb-4">&lt;- home</a>
      <h1 class="text-sm font-semibold tracking-widest text-white uppercase mb-2">/contact</h1>
      <p class="text-text-muted lowercase">
        get in touch or collaborate
      </p>
    </header>

    <ContactForm client:load />

    <div class="border-t border-border/40 mt-12 pt-8 text-center">
      <p class="text-[10px] text-text-muted uppercase tracking-widest mb-4">// or book a call</p>
      <a
        href="https://calendly.com/damiosi5banjo/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent hover:text-white underline text-xs font-mono lowercase transition-colors"
      >
        [schedule a 30min meeting]
      </a>
    </div>
  </div>
</Layout>
