              </div>
            </div>

            <!-- 2021 / Age 13 -->
            <div class="relative group">
              <div class="absolute -left-[21px] top-1 h-2 w-2 rounded-full border border-border bg-bg group-hover:bg-accent transition-colors duration-200"></div>
              <div class="space-y-0.5">
                <div class="flex items-center gap-2">
                  <span class="text-white font-semibold">2021</span>
                  <span class="text-[9px] text-text-muted lowercase">(age 13)</span>
                </div>
                <div class="text-[11px] text-white lowercase">logic expansion</div>
                <div class="text-[10px] text-text-muted lowercase leading-relaxed">
