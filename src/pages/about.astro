                </div>
              </div>
            </div>

            <!-- 2020 / Age 12 -->
            <div class="relative group">
              <div class="absolute -left-[21px] top-1 h-2 w-2 rounded-full border border-border bg-bg group-hover:bg-accent transition-colors duration-200"></div>
              <div class="space-y-0.5">
                <div class="flex items-center gap-2">
                  <span class="text-white font-semibold">2020</span>
