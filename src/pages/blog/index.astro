---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { computeReadingTime } from "../../utils/reading-time";
export const prerender = true;

const posts = (await getCollection("blog")).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const pageTitle = "damilare.code (blog)";
const pageDescription = "technical articles on systems programming, compilers, runtime tools, and infrastructure by damilare osibanjo";
const pageUrl = "https://devdami.varityweb.com/blog";

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: pageTitle,
  description: pageDescription,
  url: pageUrl,
  publisher: {
    "@type": "Person",
    name: "Damilare Osibanjo",
    url: "https://devdami.varityweb.com",
    sameAs: [
      "https://github.com/dev-dami",
      "https://www.linkedin.com/in/damilare-osibanjo/"
    ]
  },
  blogPost: posts.map(post => ({
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.date,
    url: `${pageUrl}/${post.slug}`,
    keywords: post.data.tags,
    author: {
      "@type": "Person",
      name: "Damilare Osibanjo"
    }
  }))
};
---

<Layout title={pageTitle} description={pageDescription} canonical={pageUrl}>
  {/* JSON-LD Structured Data */}
  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />

  <div class="max-w-md mx-auto py-16 font-mono text-xs text-text leading-relaxed">
    <!-- Header -->
    <header class="mb-12 text-center">
      <h1 class="text-sm font-semibold tracking-widest text-white uppercase mb-2">/blog</h1>
      <p class="text-text-muted lowercase">technical articles &amp; systems deep-dives</p>
      <div class="mt-4">
        <a href="/checklist/build-experience" class="text-accent hover:text-white underline lowercase">
          free checklist →
        </a>
      </div>
    </header>

    <!-- Post list -->
    <div class="space-y-8">
      {posts.map((post) => {
        const date = post.data.date instanceof Date ? post.data.date : new Date(post.data.date);
        const rt = post.data.readingTime || (post.body ? computeReadingTime(post.body) : 5);
        return (
          <article class="group">
            {post.data.series && (
              <div class="mb-1 text-[10px] text-accent/60 lowercase">
                // {post.data.series.name} · part {post.data.series.order}
              </div>
            )}
            <h2 class="text-sm font-semibold text-white group-hover:text-accent transition-colors mb-1 lowercase">
              <a href={`/blog/${post.slug}`} class="hover:underline">{post.data.title}</a>
            </h2>
            <p class="text-text-muted mt-1 mb-2 leading-relaxed lowercase">
              {post.data.description}
            </p>
            <div class="flex flex-wrap items-center gap-3 text-[10px] text-text-muted lowercase">
              <time>{date.toDateString().toLowerCase()}</time>
              <span>·</span>
              <span>{rt} min read</span>
              <span>·</span>
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag: string) => (
                  <span>#{tag.toLowerCase()}</span>
                ))}
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</Layout>
