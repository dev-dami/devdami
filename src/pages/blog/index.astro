---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { computeReadingTime } from "../../utils/reading-time";

const posts = (await getCollection("blog")).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const pageTitle = "Damilare Osibanjo - Blog";
const pageDescription = "Technical articles on systems programming, compilers, runtime tools, and infrastructure by Damilare Osibanjo";
const pageUrl = "https://devdami.varityweb.com/blog";
---

<Layout title={pageTitle} description={pageDescription} canonical={pageUrl}>

  {/* JSON-LD Structured Data */}
  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": pageTitle,
      "description": pageDescription,
      "url": pageUrl,
      "publisher": {
        "@type": "Person",
        "name": "Damilare Osibanjo",
        "url": "https://devdami.varityweb.com",
        "sameAs": [
          "https://github.com/dev-dami",
          "https://www.linkedin.com/in/damilare-osibanjo/"
        ]
      },
      "blogPost": posts.map(post => ({
        "@type": "BlogPosting",
        "headline": post.data.title,
        "description": post.data.description,
        "datePublished": post.data.date,
        "url": `${pageUrl}/${post.slug}`,
        "keywords": post.data.tags,
        "author": {
          "@type": "Person",
          "name": "Damilare Osibanjo"
        }
      }))
    })}
  </script>

  <div class="mx-auto max-w-blog space-y-8">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-3xl md:text-4xl font-normal tracking-wide text-text-dark">Blog</h1>
      <a
        href="/checklist/build-experience"
        class="hidden sm:inline-flex text-xs font-mono text-accent hover:text-accent-hover border border-accent/30 px-3 py-1.5 rounded transition-colors"
      >
        Free Checklist →
      </a>
    </div>

    {posts.map((post) => {
      const date = post.data.date instanceof Date ? post.data.date : new Date(post.data.date);
      return (
        <article class="group border-b border-border pb-6 transition-all duration-200 hover:border-accent/50">
          {post.data.series && (
            <div class="mb-2">
              <span class="text-xs font-mono text-accent border border-accent/30 bg-accent/5 px-2 py-0.5 rounded">
                {post.data.series.name} • Part {post.data.series.order}
              </span>
            </div>
          )}
          <a href={`/blog/${post.slug}`} class="block">
            <h2 class="text-xl md:text-2xl font-semibold text-text-dark group-hover:text-accent transition-colors">
              {post.data.title}
            </h2>
          </a>
          <p class="mt-2 text-sm text-text leading-relaxed">
            {post.data.description}
          </p>
          <div class="mt-3 flex items-center gap-3 text-xs">
            <time class="font-mono text-muted">{date.toDateString()}</time>
            {(() => {
              const rt = post.data.readingTime || (post.body ? computeReadingTime(post.body) : null);
              return rt ? (
                <>
                  <span class="text-border">•</span>
                  <span class="font-mono text-muted">{rt} min read</span>
                </>
              ) : null;
            })()}
            <span class="text-border">•</span>
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag: string) => (
                <span class="px-2 py-0.5 bg-surface border border-border rounded text-muted">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </article>
      );
    })}
  </div>
</Layout>
