---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const siteTitle = "Damilare Osibanjo - Blog";
const siteDescription = "Technical articles on systems programming, compilers, runtime tools, and infrastructure by Damilare Osibanjo";
const siteUrl = "https://devdami.varityweb.com/blog";
---

<Layout>
  {/* SEO Meta Tags */}
  <meta name="title" content={siteTitle} />
  <meta name="description" content={siteDescription} />
  <meta property="og:title" content={siteTitle} />
  <meta property="og:description" content={siteDescription} />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:type" content="website" />
  <meta name="twitter:title" content={siteTitle} />
  <meta name="twitter:description" content={siteDescription} />
  <meta name="twitter:card" content="summary_large_image" />

  {/* JSON-LD Structured Data */}
  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": siteTitle,
      "description": siteDescription,
      "url": siteUrl,
      "publisher": {
        "@type": "Person",
        "name": "Damilare Osibanjo",
        "url": "https://devdami.varityweb.com",
        "sameAs": [
          "https://github.com/dev-dami",
          "https://www.linkedin.com/in/damilare-osibanjo/"
        ]
      },
      "blogPost": posts.map(post => ({
        "@type": "BlogPosting",
        "headline": post.data.title,
        "description": post.data.description,
        "datePublished": post.data.date,
        "url": `${siteUrl}/${post.slug}`,
        "keywords": post.data.tags,
        "author": {
          "@type": "Person",
          "name": "Damilare Osibanjo"
        }
      }))
    })}
  </script>

  <div class="mx-auto max-w-blog space-y-8">
    <h1 class="text-3xl md:text-4xl font-normal tracking-wide text-text-dark mb-8">Blog</h1>

    {posts.map((post) => {
      const date = post.data.date instanceof Date ? post.data.date : new Date(post.data.date);
      return (
        <article class="group border-b border-border pb-6 transition-all duration-200 hover:border-accent/50">
          <a href={`/blog/${post.slug}`} class="block">
            <h2 class="text-xl md:text-2xl font-semibold text-text-dark group-hover:text-accent transition-colors">
              {post.data.title}
            </h2>
          </a>
          <p class="mt-2 text-sm text-text leading-relaxed">
            {post.data.description}
          </p>
          <div class="mt-3 flex items-center gap-3 text-xs">
            <time class="font-mono text-muted">{date.toDateString()}</time>
            <span class="text-border">•</span>
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag: string) => (
                <span class="px-2 py-0.5 bg-surface border border-border rounded text-muted">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </article>
      );
    })}
  </div>
</Layout>
