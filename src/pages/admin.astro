---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
export const prerender = true;

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout
  title="admin — damilare osibanjo"
  description="send broadcast emails to subscribers."
>
  <div class="max-w-md mx-auto py-16 font-mono text-xs text-text leading-relaxed">
    <header class="mb-12 text-center">
      <h1 class="text-sm font-semibold tracking-widest text-white uppercase mb-2">
        /admin: broadcast
      </h1>
      <p class="text-text-muted lowercase">
        send a new blog post notification to your resend audience.
      </p>
    </header>

    <!-- Auth gate -->
    <div id="auth-gate" class="border-t border-b border-border/40 py-6 mb-8 font-mono text-center">
      <label class="block text-xs font-semibold text-white mb-2 lowercase">// admin token</label>
      <div class="flex flex-col gap-3 max-w-xs mx-auto">
        <input
          id="admin-token"
          type="password"
          placeholder="admin_secret"
          class="px-3 py-2 bg-transparent border-b border-border/60 text-xs text-text placeholder:text-muted/50 font-mono outline-none focus:border-white transition-colors text-center"
        />
        <button
          id="auth-btn"
          class="mt-2 text-accent hover:text-white underline cursor-pointer text-xs font-mono lowercase"
        >
          [unlock]
        </button>
      </div>
      <p id="auth-error" class="mt-2 text-[10px] font-mono text-red-400 hidden lowercase"></p>
    </div>

    <!-- Broadcast form (hidden until authenticated) -->
    <div id="broadcast-form" class="hidden border-t border-border/40 pt-8 space-y-6">
      <!-- Post selector -->
      <div class="space-y-1">
        <label class="block text-[10px] text-white uppercase tracking-wider font-mono">// select a post</label>
        <select
          id="post-select"
          class="w-full px-3 py-2 bg-surface border border-border/60 text-xs text-text font-mono outline-none focus:border-white transition-colors"
        >
          <option value="" class="bg-bg">— manual entry —</option>
          {posts.map((post) => (
            <option value={post.slug} data-title={post.data.title} data-description={post.data.description} class="bg-bg">
              {post.data.title.toLowerCase()}
            </option>
          ))}
        </select>
      </div>

      <div class="space-y-4">
        <div class="space-y-1">
          <label for="slug" class="block text-[10px] text-white uppercase tracking-wider font-mono">// slug</label>
          <input
            id="slug"
            type="text"
            placeholder="my-blog-post-slug"
            class="w-full px-3 py-2 bg-transparent border-b border-border/60 text-xs text-text placeholder:text-muted/50 font-mono outline-none focus:border-white transition-colors"
          />
        </div>
        <div class="space-y-1">
          <label for="title" class="block text-[10px] text-white uppercase tracking-wider font-mono">// title</label>
          <input
            id="title"
            type="text"
            placeholder="how cve-2026-33017 turned ai workflows into remote shells"
            class="w-full px-3 py-2 bg-transparent border-b border-border/60 text-xs text-text placeholder:text-muted/50 font-mono outline-none focus:border-white transition-colors"
          />
        </div>
        <div class="space-y-1">
          <label for="description" class="block text-[10px] text-white uppercase tracking-wider font-mono">// description</label>
          <textarea
            id="description"
            rows="3"
            placeholder="a deep technical breakdown..."
            class="w-full px-3 py-2 bg-transparent border-b border-border/60 text-xs text-text placeholder:text-muted/50 font-mono outline-none focus:border-white transition-colors resize-y"
          ></textarea>
        </div>
      </div>

      <!-- Email preview -->
      <div id="preview" class="hidden border border-border/40 bg-surface/20 p-4 font-mono text-text-muted lowercase">
        <div class="text-[9px] uppercase tracking-wider text-white mb-2">// email preview</div>
        <div class="space-y-2 text-[10px]">
          <div id="preview-subject" class="text-white font-semibold"></div>
          <div id="preview-body" class="whitespace-pre-wrap leading-relaxed"></div>
        </div>
      </div>

      <div class="pt-4 text-center">
        <button
          id="send-btn"
          disabled
          class="text-text-muted cursor-not-allowed text-xs font-mono lowercase"
        >
          [send broadcast]
        </button>
        <p id="send-status" class="mt-2 text-[10px] font-mono hidden lowercase"></p>
      </div>
    </div>
  </div>
</Layout>

<script>
  const TOKEN_INPUT = document.getElementById("admin-token") as HTMLInputElement;
  const AUTH_BTN = document.getElementById("auth-btn") as HTMLButtonElement;
  const AUTH_ERROR = document.getElementById("auth-error") as HTMLElement;
  const AUTH_GATE = document.getElementById("auth-gate") as HTMLElement;
  const FORM = document.getElementById("broadcast-form") as HTMLElement;
  const POST_SELECT = document.getElementById("post-select") as HTMLSelectElement;
  const SLUG = document.getElementById("slug") as HTMLInputElement;
  const TITLE = document.getElementById("title") as HTMLInputElement;
  const DESC = document.getElementById("description") as HTMLTextAreaElement;
  const PREVIEW = document.getElementById("preview") as HTMLElement;
  const PREVIEW_SUBJECT = document.getElementById("preview-subject") as HTMLElement;
  const PREVIEW_BODY = document.getElementById("preview-body") as HTMLElement;
  const SEND_BTN = document.getElementById("send-btn") as HTMLButtonElement;
  const SEND_STATUS = document.getElementById("send-status") as HTMLElement;

  let adminToken = "";

  // --- Auth ---
  AUTH_BTN.addEventListener("click", () => {
    const token = TOKEN_INPUT.value.trim();
    if (!token) {
      AUTH_ERROR.textContent = "enter an admin token.";
      AUTH_ERROR.classList.remove("hidden");
      return;
    }
    adminToken = token;
    AUTH_GATE.classList.add("hidden");
    FORM.classList.remove("hidden");
    AUTH_ERROR.classList.add("hidden");
  });

  TOKEN_INPUT.addEventListener("keydown", (e) => {
    if (e.key === "Enter") AUTH_BTN.click();
  });

  // --- Post select auto-fill ---
  POST_SELECT.addEventListener("change", () => {
    const opt = POST_SELECT.selectedOptions[0];
    if (opt && opt.value) {
      SLUG.value = opt.value;
      TITLE.value = (opt as HTMLOptionElement).dataset.title || "";
      DESC.value = (opt as HTMLOptionElement).dataset.description || "";
    }
    updatePreview();
  });

  // --- Live preview ---
  function updatePreview() {
    const title = TITLE.value.trim();
    const desc = DESC.value.trim();
    const slug = SLUG.value.trim();
    if (!title || !slug) {
      PREVIEW.classList.add("hidden");
      return;
    }
    PREVIEW_SUBJECT.textContent = `New blog post: ${title}`;
    PREVIEW_BODY.textContent = `Subject: New blog post: ${title}\n\n${desc || "(no description)"}\n\nhttps://devdami.varityweb.com/blog/${slug}/`;
    const fieldsFilled = title && slug;
    SEND_BTN.disabled = !fieldsFilled;
    SEND_BTN.className = fieldsFilled
      ? "text-accent hover:text-white underline cursor-pointer text-xs font-mono lowercase"
      : "text-text-muted cursor-not-allowed text-xs font-mono lowercase";
    PREVIEW.classList.remove("hidden");
  }

  [SLUG, TITLE, DESC].forEach((el) => el.addEventListener("input", updatePreview));

  // --- Send ---
  SEND_BTN.addEventListener("click", async () => {
    const slug = SLUG.value.trim();
    const title = TITLE.value.trim();
    const desc = DESC.value.trim();

    if (!slug || !title) return;

    SEND_BTN.disabled = true;
    SEND_BTN.textContent = "[sending...]";
    SEND_STATUS.className = "mt-2 text-[10px] font-mono text-text-muted";
    SEND_STATUS.textContent = "sending broadcast...";
    SEND_STATUS.classList.remove("hidden");

    try {
      const res = await fetch("/api/admin/send-broadcast", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${adminToken}`,
        },
        body: JSON.stringify({ slug, title, description: desc }),
      });
      const data = await res.json();
      if (res.ok) {
        SEND_STATUS.textContent = `broadcast sent! ${data.data?.id ? `id: ${data.data.id}` : ""}`;
        SEND_STATUS.className = "mt-2 text-[10px] font-mono text-accent";
      } else {
        SEND_STATUS.textContent = `error: ${data.error || "unknown error"}`;
        SEND_STATUS.className = "mt-2 text-[10px] font-mono text-red-400";
      }
    } catch {
      SEND_STATUS.textContent = "network error — check your connection.";
      SEND_STATUS.className = "mt-2 text-[10px] font-mono text-red-400";
    }

    SEND_BTN.disabled = false;
    SEND_BTN.textContent = "[send broadcast]";
  });
</script>
