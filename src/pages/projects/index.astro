---
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";
import { fetchRepoStats } from "../../utils/github";
export const prerender = true;

const pageTitle = "dami.projects";
const pageDescription = "open-source projects by damilare osibanjo — systems programming, compilers, emulators, and infrastructure tools.";

const statsResults = await Promise.allSettled(
  projects.filter((p) => p.githubUrl).map((p) => fetchRepoStats(p.githubUrl!))
);
const statsMap = new Map<string, { stars: number | null; forks: number | null }>();
let totalStars = 0;
let totalForks = 0;
let statsIdx = 0;
projects.forEach((p) => {
  if (p.githubUrl) {
    const s = statsResults[statsIdx].status === "fulfilled" ? statsResults[statsIdx].value : null;
    const stars = s?.stars ?? null;
    const forks = s?.forks ?? null;
    statsMap.set(p.slug, { stars, forks });
    if (stars !== null) totalStars += stars;
    if (forks !== null) totalForks += forks;
    statsIdx++;
  } else {
    statsMap.set(p.slug, { stars: null, forks: null });
  }
});

const uniqueLanguages = new Set(projects.map((p) => p.language).filter(Boolean));
const languageCount = uniqueLanguages.size;
---

<Layout title={pageTitle} description={pageDescription} canonical="https://devdami.varityweb.com/projects/">
  <div class="max-w-xl mx-auto py-16 font-mono text-xs text-text leading-relaxed">
    <!-- Page Header -->
    <header class="mb-12 text-center">
      <a href="/" class="text-text-muted hover:text-white transition-all duration-150 block mb-4">&lt;- home</a>
      <h1 class="text-sm font-semibold tracking-widest text-white uppercase mb-2">/projects</h1>
      <p class="text-text-muted lowercase">
        systems-level open-source work — kernels, compilers, emulators, runtimes, and tools
      </p>

      <!-- Stats summary bar -->
      <div class="flex flex-wrap items-center justify-center gap-3 mt-4 text-[10px] text-text-muted lowercase">
        <span>{totalStars} stars across {projects.length} projects</span>
        <span>·</span>
        <span>{languageCount} languages</span>
        <span>·</span>
        <span>{totalForks} forks</span>
      </div>
    </header>

    <!-- Project list -->
    <div class="grid grid-cols-1 gap-4 w-full">
      {projects.map((p) => {
        const stats = statsMap.get(p.slug)!;
        return (
          <article class="group relative overflow-hidden bg-surface/30 border border-border/40 hover:border-accent/40 rounded-lg p-5 transition-all duration-500 ease-out flex flex-col justify-between min-h-[100px] text-left hover:bg-surface/40 hover:-translate-y-0.5 cursor-pointer">
            <div class="flex items-baseline justify-between mb-1 lowercase">
              <h2 class="text-sm font-semibold text-white group-hover:text-accent transition-colors duration-150">
                <a href={`/projects/${p.slug}`} class="hover:underline focus:outline-none">
                  <span class="absolute inset-0" aria-hidden="true"></span>
                  {p.name}
                </a>
              </h2>
              <div class="flex items-center gap-2 text-[10px] text-text-muted relative z-10">
                {p.npm && (
                  <a
                    href={`https://www.npmjs.com/package/${p.name}`}
                    target="_blank"
                    class="text-accent hover:text-white underline"
                  >
                    [npm]
                  </a>
                )}
                {stats.stars !== null && <span>★{stats.stars}</span>}
              </div>
            </div>
            <p class="text-text-muted mt-1 mb-3 leading-relaxed lowercase font-mono">
              {p.description}
            </p>
            <div class="flex flex-wrap items-center justify-between gap-3 text-[10px] text-text-muted lowercase font-mono relative z-10 font-mono">
              <div class="flex items-center gap-3">
                {p.language && <span>{p.language}</span>}
                {p.language && <span>·</span>}
                <div class="flex flex-wrap gap-2">
                  {p.tags.slice(0, 4).map((tag) => (
                    <span>#{tag.toLowerCase()}</span>
                  ))}
                </div>
              </div>

              <div class="flex items-center gap-3">
                {p.githubUrl && (
                  <>
                    <a
                      href={p.githubUrl}
                      target="_blank"
                      class="text-accent hover:text-white underline"
                    >
                      [github]
                    </a>
                    <a
                      href={`${p.githubUrl}/fork`}
                      target="_blank"
                      class="text-accent hover:text-white underline"
                    >
                      [fork]
                    </a>
                  </>
                )}
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</Layout>
