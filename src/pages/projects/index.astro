---
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";
import { fetchRepoStats } from "../../utils/github";
export const prerender = true;

const pageTitle = "Projects — Damilare Osibanjo";
const pageDescription =
  "Open-source projects by Damilare Osibanjo — systems programming, compilers, emulators, and infrastructure tools.";

const statsResults = await Promise.allSettled(
  projects.filter((p) => p.githubUrl).map((p) => fetchRepoStats(p.githubUrl!))
);
const statsMap = new Map<string, { stars: number | null; forks: number | null }>();
let totalStars = 0;
let totalForks = 0;
let statsIdx = 0;
projects.forEach((p) => {
  if (p.githubUrl) {
    const s = statsResults[statsIdx].status === "fulfilled" ? statsResults[statsIdx].value : null;
    const stars = s?.stars ?? null;
    const forks = s?.forks ?? null;
    statsMap.set(p.slug, { stars, forks });
    if (stars !== null) totalStars += stars;
    if (forks !== null) totalForks += forks;
    statsIdx++;
  } else {
    statsMap.set(p.slug, { stars: null, forks: null });
  }
});

const uniqueLanguages = new Set(projects.map((p) => p.language).filter(Boolean));
const languageCount = uniqueLanguages.size;

const langAccent = (lang: string | undefined): string => {
  const colors: Record<string, string> = {
    Rust: "border-l-[#dea584]",
    Go: "border-l-[#00ADD8]",
    TypeScript: "border-l-[#3178C6]",
    Zig: "border-l-[#F7A41D]",
  };
  return colors[lang ?? ""] ?? "border-l-accent/40";
};
---


<Layout title={pageTitle} description={pageDescription} canonical="https://devdami.varityweb.com/projects/">
  <div class="mx-auto max-w-content">
    <!-- Page Header -->
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-normal tracking-wide text-text-dark">Projects</h1>
      <p class="text-sm text-text/70 mt-2 max-w-2xl">
        Systems-level open-source work — kernels, compilers, emulators, runtimes, and infrastructure tools.
      </p>

      <!-- Stats summary bar -->
      <div class="flex flex-wrap items-center gap-x-5 gap-y-1 mt-5 text-xs font-mono text-muted border border-border/50 bg-surface/10 rounded-lg px-4 py-2.5">
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-accent/70" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <span class="text-white/80">{totalStars}</span> stars across <span class="text-white/80">{projects.length}</span> projects
        </span>
        <span class="hidden sm:inline text-border">/</span>
        <span><span class="text-white/80">{languageCount}</span> languages</span>
        <span class="hidden sm:inline text-border">/</span>
        <span><span class="text-white/80">{totalForks}</span> forks</span>
      </div>
    </div>

    <!-- Project list -->
    <div class="space-y-3">
      {projects.map((p) => {
        const stats = statsMap.get(p.slug)!;
        return (
          <a
            href={`/projects/${p.slug}`}
            class={`group block border-l-2 ${langAccent(p.language)} border-border bg-surface/5 rounded-r-sm px-5 py-4 transition-all duration-200 hover:bg-surface/20 hover:border-l-white/40`}
          >
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2.5 mb-1.5">
                  <span class="text-xs font-mono text-accent/40 select-none">{p.number}.</span>
                  <h2 class="text-base md:text-lg font-semibold text-white group-hover:text-accent transition-colors font-mono tracking-tight">
                    {p.name}
                  </h2>
                  {p.npm && (
                    <span class="px-1.5 py-0.5 text-xs font-mono text-accent border border-accent/30 bg-accent/5 leading-none rounded">
                      npm
                    </span>
                  )}
                </div>
                <p class="text-xs md:text-sm text-white/70 leading-relaxed mb-2.5 max-w-3xl">
                  {p.description}
                </p>
                <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                  {p.language && (
                    <span class="inline-flex items-center gap-1.5 text-xs font-mono text-muted">
                      <span class="w-2 h-2 rounded-full bg-accent/80" />
                      {p.language}
                    </span>
                  )}
                  {p.tags.slice(0, 4).map((tag) => (
                    <span class="px-1.5 py-px text-xs font-mono text-text-muted border border-border/70 rounded-sm">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>

              {/* Stats column */}
              <div class="hidden sm:flex flex-col items-end gap-1.5 shrink-0 pt-1">
                <span class="inline-flex items-center gap-1 text-xs font-mono text-muted">
                  <svg class="w-3.5 h-3.5 text-accent/60" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                  {stats.stars !== null ? stats.stars : "—"}
                </span>
                <span class="inline-flex items-center gap-1 text-xs font-mono text-muted">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M5 3.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm0 2.122a2.25 2.25 0 10-1.5 0v.878A2.25 2.25 0 005.75 8.5h1.5v2.128a2.251 2.251 0 101.5 0V8.5h1.5a2.25 2.25 0 002.25-2.25v-.878a2.25 2.25 0 10-1.5 0v.878a.75.75 0 01-.75.75h-4.5A.75.75 0 015 6.25v-.878z"/>
                  </svg>
                  {stats.forks !== null ? stats.forks : "—"}
                </span>
              </div>

              {/* Chevron (desktop) */}
              <svg
                class="hidden sm:block w-4 h-4 text-muted/50 group-hover:text-accent transition-colors shrink-0 mt-1.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
