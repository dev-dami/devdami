---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { projects } from "../../data/projects";
import { fetchRepoStats } from "../../utils/github";
export const prerender = true;

export async function getStaticPaths() {
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;

const repoStats = project.githubUrl ? await fetchRepoStats(project.githubUrl) : null;
const stars = repoStats?.stars ?? null;
const forks = repoStats?.forks ?? null;

const allProjectContent = await getCollection("projects");
const projectContent = allProjectContent.find((c) => c.slug === project.slug);
const Content = projectContent ? (await projectContent.render()).Content : null;

const allBlogPosts = await getCollection("blog");
const linkedPosts = allBlogPosts
  .filter((post) => post.data.repo === project.slug)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout
  title={`${project.name} — dami.projects`}
  description={project.description}
  canonical={`https://devdami.varityweb.com/projects/${project.slug}/`}
>
  <div class="max-w-md mx-auto py-16 font-mono text-xs text-text leading-relaxed">
    <!-- Back link -->
    <a
      href="/projects"
      class="inline-flex items-center gap-1.5 text-text-muted hover:text-white transition-colors mb-8 lowercase"
    >
      &lt;- back to projects
    </a>

    <article class="space-y-12">
      <!-- Project Header -->
      <header class="text-center">
        <h1 class="text-base font-semibold text-white lowercase mb-2">
          {project.name}
        </h1>
        <p class="text-text-muted lowercase leading-relaxed mb-4">
          {project.description}
        </p>

        <!-- Metadata bar -->
        <div class="flex flex-wrap items-center justify-center gap-3 text-[10px] text-text-muted lowercase">
          {project.language && <span>{project.language}</span>}
          {project.language && <span>·</span>}
          {stars !== null && <span>★{stars} stars</span>}
          {stars !== null && <span>·</span>}
          {forks !== null && <span>{forks} forks</span>}
          {forks !== null && <span>·</span>}
          {project.license && <span>{project.license}</span>}
          {project.license && <span>·</span>}
          <div class="flex flex-wrap gap-2 justify-center">
            {project.tags.map((tag) => (
              <span>#{tag.toLowerCase()}</span>
            ))}
          </div>
        </div>

        <!-- Action links -->
        <div class="flex flex-wrap justify-center gap-4 mt-6 text-[10px] text-text-muted lowercase">
          {project.githubUrl && (
            <>
              <a
                href={project.githubUrl}
                target="_blank"
                class="text-accent hover:text-white underline"
              >
                [github]
              </a>
              <a
                href={`${project.githubUrl}/fork`}
                target="_blank"
                class="text-accent hover:text-white underline"
              >
                [fork]
              </a>
            </>
          )}
          {project.npm && (
            <a
              href={`https://www.npmjs.com/package/${project.name}`}
              target="_blank"
              class="text-accent hover:text-white underline"
            >
              [npm]
            </a>
          )}
        </div>
      </header>

      <!-- README Section -->
      <section class="border-t border-border/40 pt-8 lowercase">
        {Content ? (
          <div class="prose prose-invert max-w-none space-y-6 text-xs text-text lowercase">
            <Content />
          </div>
        ) : (
          <div class="space-y-4">
            <p class="text-text-muted leading-relaxed">
              {project.description}
            </p>
            <p class="text-[10px] text-text-muted">
              visit the github repository for source code, documentation, and contribution guidelines.
            </p>
          </div>
        )}
      </section>

      <!-- Linked Blog Posts -->
      {linkedPosts.length > 0 && (
        <section class="border-t border-border/40 pt-8 lowercase font-mono">
          <h2 class="text-[10px] uppercase text-white tracking-widest mb-4">
            // related blog posts
          </h2>
          <div class="space-y-4">
            {linkedPosts.map((post) => (
              <a
                href={`/blog/${post.slug}`}
                class="group block"
              >
                <span class="text-white group-hover:text-accent font-semibold underline block mb-1">
                  {post.data.title}
                </span>
                <div class="text-[9px] text-text-muted">
                  {post.data.date.toDateString().toLowerCase()}
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </article>
  </div>
</Layout>
