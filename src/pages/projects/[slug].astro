---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { projects } from "../../data/projects";
import { fetchRepoStats } from "../../utils/github";
export const prerender = true;

export async function getStaticPaths() {
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;

const repoStats = await fetchRepoStats(project.githubUrl);
const stars = repoStats?.stars ?? null;
const forks = repoStats?.forks ?? null;

const allProjectContent = await getCollection("projects");
const projectContent = allProjectContent.find((c) => c.slug === project.slug);
const Content = projectContent ? (await projectContent.render()).Content : null;

const allBlogPosts = await getCollection("blog");
const linkedPosts = allBlogPosts
  .filter((post) => post.data.repo === project.slug)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout
  title={`${project.name} — Projects — Damilare Osibanjo`}
  description={project.description}
  canonical={`https://devdami.varityweb.com/projects/${project.slug}/`}
>
  <div class="mx-auto max-w-content">
    <!-- Back link -->
    <a
      href="/projects"
      class="inline-flex items-center gap-1.5 text-xs font-mono text-muted hover:text-accent transition-colors mb-6"
    >
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M15 19l-7-7 7-7" />
      </svg>
      Projects
    </a>

    <article>
      <!-- Project Header -- GitHub-style repo header -->
      <header class="border border-border bg-surface/5 rounded-lg px-5 md:px-6 py-5 mb-8">
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2.5 mb-2">
              <span class="text-sm font-mono text-accent/40 select-none shrink-0">
                {project.number}.
              </span>
              <h1 class="text-xl md:text-2xl font-semibold tracking-tight text-text-dark font-mono">
                {project.name}
              </h1>
              {project.npm && (
                <span class="px-1.5 py-0.5 text-xs font-mono text-accent border border-accent/40 leading-none rounded">
                  npm
                </span>
              )}
            </div>
            <p class="text-sm text-white/70 leading-relaxed max-w-3xl">
              {project.description}
            </p>

            <!-- GitHub-style metadata bar -->
            <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5 mt-4">
              {project.language && (
                <span class="inline-flex items-center gap-1.5 text-xs font-mono text-muted">
                  <span class="w-2.5 h-2.5 rounded-full bg-accent/80" />
                  {project.language}
                </span>
              )}
              {stars !== null && (
                <span class="inline-flex items-center gap-1 text-xs font-mono text-muted">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                  {stars} stars
                </span>
              )}
              {forks !== null && (
                <span class="inline-flex items-center gap-1 text-xs font-mono text-muted">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M5 3.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm0 2.122a2.25 2.25 0 10-1.5 0v.878A2.25 2.25 0 005.75 8.5h1.5v2.128a2.251 2.251 0 101.5 0V8.5h1.5a2.25 2.25 0 002.25-2.25v-.878a2.25 2.25 0 10-1.5 0v.878a.75.75 0 01-.75.75h-4.5A.75.75 0 015 6.25v-.878z"/>
                  </svg>
                  {forks} forks
                </span>
              )}
              {project.license && (
                <span class="text-xs font-mono text-muted">
                  {project.license}
                </span>
              )}
              {project.tags.map((tag) => (
                <span class="px-1.5 py-px text-xs font-mono text-text-muted border border-border/70 rounded">
                  {tag}
                </span>
              ))}
            </div>
          </div>

          <!-- Star badge (desktop) -->
          {stars !== null && (
            <a
              href={`${project.githubUrl}/stargazers`}
              target="_blank"
              class="hidden sm:flex items-center gap-1.5 px-3 py-1.5 border border-border rounded text-sm text-muted font-mono shrink-0 hover:border-accent/40 hover:text-accent transition-all"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              <span>{stars}</span>
            </a>
          )}
        </div>

        <!-- Action buttons -->
        <div class="flex flex-wrap items-center gap-2 mt-5 pt-4 border-t border-border/50">
          <a
            href={project.githubUrl}
            target="_blank"
            class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg bg-accent hover:bg-accent-hover text-white transition-all shadow-lg"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
          {project.npm && (
            <a
              href={`https://www.npmjs.com/package/${project.name}`}
              target="_blank"
              class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg border border-border/80 bg-surface/50 text-text hover:text-text-dark hover:border-accent/50 transition-all"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M1.763 0C.786 0 0 .786 0 1.763v20.474C0 23.214.786 24 1.763 24h20.474c.977 0 1.763-.786 1.763-1.763V1.763C24 .786 23.214 0 22.237 0zM5.13 5.323l13.837.019-.009 13.838h-4.464l-.01-9.408H9.604v9.424H5.13z"/>
              </svg>
              npm
            </a>
          )}
          <a
            href={`${project.githubUrl}/fork`}
            target="_blank"
            class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg border border-border/80 bg-surface/50 text-text hover:text-text-dark hover:border-accent/50 transition-all"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M5 3.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm0 2.122a2.25 2.25 0 10-1.5 0v.878A2.25 2.25 0 005.75 8.5h1.5v2.128a2.251 2.251 0 101.5 0V8.5h1.5a2.25 2.25 0 002.25-2.25v-.878a2.25 2.25 0 10-1.5 0v.878a.75.75 0 01-.75.75h-4.5A.75.75 0 015 6.25v-.878z"/>
            </svg>
            Fork
          </a>
        </div>
      </header>

      <!-- README Section -->
      <section class="mb-12">
        {Content ? (
          <div class="prose prose-invert max-w-none space-y-6">
            <Content />
          </div>
        ) : (
          <div class="border border-border/50 rounded-lg px-5 md:px-6 py-6 bg-surface/5">
            <div class="flex items-center gap-2 mb-4">
              <svg class="w-4 h-4 text-muted" fill="currentColor" viewBox="0 0 24 24">
                <path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zm0 2v12h16V6H4zm2 2h12v2H6V8zm0 4h8v2H6v-2z"/>
              </svg>
              <h2 class="text-xs font-mono tracking-widest text-muted uppercase">
                README
              </h2>
            </div>
            <div class="space-y-4">
              <p class="text-sm text-white/70 leading-relaxed">
                {project.description}
              </p>
              <p class="text-xs text-muted font-mono">
                Visit the GitHub repository for source code, documentation, and contribution guidelines.
              </p>
            </div>
          </div>
        )}
      </section>

      <!-- Linked Blog Posts -->
      {linkedPosts.length > 0 && (
        <section class="mb-12">
          <div class="border-t border-border/50 mb-6" />
          <h2 class="text-xs font-mono tracking-widest text-muted uppercase mb-4 term-header">
            Related Blog Posts
          </h2>
          <div class="space-y-2">
            {linkedPosts.map((post) => (
              <a
                href={`/blog/${post.slug}`}
                class="group block term-card rounded-sm border border-border bg-surface/10 px-4 py-3 transition-all duration-150 hover:bg-surface/30"
              >
                <div class="flex items-start gap-3">
                  <div class="flex-1 min-w-0">
                    <h3 class="text-sm font-medium text-white group-hover:text-accent transition-colors">
                      {post.data.title}
                    </h3>
                    <div class="flex items-center gap-2 mt-1">
                      <time class="text-xs text-muted font-mono">
                        {post.data.date.toDateString()}
                      </time>
                      {post.data.series && (
                        <span class="text-xs font-mono text-accent/70 border border-accent/20 bg-accent/5 px-1.5 py-px rounded">
                          {post.data.series.name}
                        </span>
                      )}
                    </div>
                  </div>
                  <svg
                    class="w-4 h-4 text-muted group-hover:text-accent transition-colors shrink-0 mt-1"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </article>
  </div>
</Layout>
