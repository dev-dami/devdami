              <span class="px-2 py-0.5 text-[11px] font-mono border border-border/50 rounded-sm text-text">Lua</span>
              <span class="px-2 py-0.5 text-[11px] font-mono border border-border/50 rounded-sm text-text">Zig</span>
            </div>
