              class="w-28 h-28 rounded-md object-cover ring-1 ring-accent/20"
              loading="lazy"
              width="112"
              height="112"
            />
          </div>

          <!-- Infobox data -->
          <table class="w-full text-xs">
            <tbody>
              <tr class="border-b border-border/20">
                <td class="px-4 py-2 text-muted/70 font-mono w-[90px] align-top">Born</td>
                <td class="px-4 py-2 text-text">2008 (age 17)<br /><span class="text-muted/60">Nigeria</span></td>
              </tr>
              <tr class="border-b border-border/20">
