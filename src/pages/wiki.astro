---
import Layout from "../layouts/Layout.astro";
export const prerender = true;

const pageTitle = "Damilare Osibanjo — Personal Wiki";
const pageDescription = "Personal wiki for Damilare Osibanjo — systems programmer, security researcher, and compiler engineer.";
const pageUrl = "https://devdami.varityweb.com/wiki";
---

<Layout title={pageTitle} description={pageDescription} canonical={pageUrl}>
  <div class="max-w-2xl mx-auto py-16 font-mono text-xs text-text leading-relaxed">
    <!-- Header -->
    <header class="mb-12 text-center">
      <a href="/" class="text-text-muted hover:text-white transition-all duration-150 block mb-4">&lt;- home</a>
      <h1 class="text-sm font-semibold tracking-widest text-white uppercase mb-2">// wiki: damilare osibanjo</h1>
      <p class="text-text-muted lowercase">/dəˈmɪlərɛɪ ˌoʊʃɪˈbɑndʒoʊ/ · free personal encyclopedia</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
      <!-- Left 2 columns: Wiki Main Content -->
      <div class="md:col-span-2 space-y-6">
        <!-- Biography -->
        <section id="biography" class="bg-surface/30 border border-border/40 hover:border-accent/40 rounded-lg p-5 transition-all duration-500 ease-out space-y-4">
          <h2 class="text-[10px] uppercase text-white tracking-widest">// 1. biography</h2>
          <p class="text-text-muted lowercase">
            Damilare Osibanjo is a systems and software programmer. He began his programming journey at approximately age 12, developing games on Roblox using Lua. This laid the foundation for his work in low-level engineering.
          </p>
          <p class="text-text-muted lowercase">
            At age 14, he transitioned to Python, building automation tools and APIs. During this period, his interest shifted toward understanding internal system behaviors — memory consumption, concurrency mechanics, and OS-level operations.
          </p>
          <p class="text-text-muted lowercase">
            By age 16, he began designing compilers, runtime tools, and studying memory-safety in Rust, Go, and C.
          </p>
        </section>

        <!-- Notable Works -->
        <section id="notable-works" class="bg-surface/30 border border-border/40 hover:border-accent/40 rounded-lg p-5 transition-all duration-500 ease-out space-y-4">
          <h2 class="text-[10px] uppercase text-white tracking-widest">// 2. notable works</h2>
          <ul class="space-y-4">
            <li class="group">
              <span class="text-white font-semibold lowercase">carv:</span>
              <p class="text-text-muted mt-1 leading-relaxed lowercase">
                An opinionated systems programming language compiling to C for ARM Cortex-M targets. Implements Pratt parsing, ownership tracking, and a custom async/await runtime.
              </p>
            </li>
            <li class="group">
              <span class="text-white font-semibold lowercase">cve-2026-33017:</span>
              <p class="text-text-muted mt-1 leading-relaxed lowercase">
                Discovered a remote code execution vulnerability in Langflow. Reached arbitrary exec() execution through an exploit chain of components with zero sandboxing.
              </p>
            </li>
            <li class="group">
              <span class="text-white font-semibold lowercase">game boy emulator:</span>
              <p class="text-text-muted mt-1 leading-relaxed lowercase">
                A cycle-accurate Game Boy emulator written in Zig. Built from scratch with zero dependencies, exploring memory-mapped I/O and interrupt handling.
              </p>
            </li>
          </ul>
        </section>

        <!-- Technical Skills -->
        <section id="skills" class="bg-surface/30 border border-border/40 hover:border-accent/40 rounded-lg p-5 transition-all duration-500 ease-out space-y-4">
          <h2 class="text-[10px] uppercase text-white tracking-widest">// 3. technical skills</h2>
          <ul class="space-y-2.5 text-text-muted">
            <li class="flex items-center gap-2">
              <span class="text-white font-semibold min-w-[90px] lowercase">systems:</span>
              <span class="lowercase">rust, go, c, zig</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-white font-semibold min-w-[90px] lowercase">backend:</span>
              <span class="lowercase">typescript, node.js, python, bun</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-white font-semibold min-w-[90px] lowercase">compilers:</span>
              <span class="lowercase">pratt parsing, ir design, codegen</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-white font-semibold min-w-[90px] lowercase">infra:</span>
              <span class="lowercase">linux, docker, git, postgresql</span>
            </li>
          </ul>
        </section>

        <!-- Philosophy -->
        <section id="philosophy" class="bg-surface/30 border border-border/40 hover:border-accent/40 rounded-lg p-5 transition-all duration-500 ease-out space-y-4">
          <h2 class="text-[10px] uppercase text-white tracking-widest">// 4. philosophy</h2>
          <p class="text-text-muted leading-relaxed lowercase">
            Damilare advocates for understanding systems at the lowest feasible level of abstraction. Working close to the hardware fundamentally changes how one designs at the application layer. Explicit, readable code is always preferred over clever indirection.
          </p>
        </section>
      </div>

      <!-- Right 1 column: Infobox + Table of Contents -->
      <div class="space-y-6">
        <!-- Infobox Sidebar -->
        <aside class="bg-surface/40 border border-border/60 rounded-lg p-5 space-y-4">
          <div class="flex flex-col items-center text-center pb-4 border-b border-border/40">
            <img
              src="/icon.png"
              alt="damilare osibanjo"
              class="w-20 h-20 rounded-full object-cover border border-border/60 mb-3"
            />
            <span class="text-white font-semibold text-xs lowercase">damilare osibanjo</span>
            <span class="text-[10px] text-text-muted mt-0.5 lowercase">systems developer</span>
          </div>
          
          <div class="space-y-3 text-[10px]">
            <div>
              <span class="text-white block lowercase">born:</span>
              <span class="text-text-muted lowercase">2008 (age 17) · nigeria</span>
            </div>
            <div>
              <span class="text-white block lowercase">occupation:</span>
              <span class="text-text-muted lowercase">systems programmer, security researcher, compiler engineer</span>
            </div>
            <div>
              <span class="text-white block lowercase">notable:</span>
              <span class="text-text-muted lowercase">carv language, cve-2026-33017, kiattp, game boy emulator</span>
            </div>
          </div>
        </aside>

        <!-- TOC Box -->
        <aside class="bg-surface/40 border border-border/60 rounded-lg p-4 space-y-3">
          <div class="text-white text-[10px] uppercase tracking-wider font-semibold">// contents</div>
          <ul class="space-y-1.5 text-[11px] text-text-muted">
            <li class="hover:translate-x-1 transition-transform duration-150">
              1. <a href="#biography" class="hover:text-white underline">biography</a>
            </li>
            <li class="hover:translate-x-1 transition-transform duration-150">
              2. <a href="#notable-works" class="hover:text-white underline">notable works</a>
            </li>
            <li class="hover:translate-x-1 transition-transform duration-150">
              3. <a href="#skills" class="hover:text-white underline">technical skills</a>
            </li>
            <li class="hover:translate-x-1 transition-transform duration-150">
              4. <a href="#philosophy" class="hover:text-white underline">philosophy</a>
            </li>
          </ul>
        </aside>
      </div>
    </div>
  </div>
</Layout>
