  section[id] {
    scroll-margin-top: 6rem;
  }

  /* Superscript reference links */
  sup a {
    font-size: inherit;
    line-height: 1;
  }

  /* TOC list spacing */
  .toc-list {
    list-style: none;
    padding: 0;
  }

  /* Infobox table spacing */
