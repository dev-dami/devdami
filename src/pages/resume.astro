---
import "../styles/global.css";
export const prerender = true;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Resume — Damilare Osibanjo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" />
  </head>
  <body class="min-h-screen bg-bg text-text font-mono antialiased">

    <!-- Toolbar (hidden on print) -->
    <div class="no-print border-b border-border/40 py-4 max-w-md mx-auto flex items-center justify-between text-xs font-mono">
      <a href="/" class="text-text-muted hover:text-white transition-colors">&lt;- back</a>
      <div class="flex items-center gap-4">
        <span class="text-text-muted">resume_v1.0</span>
        <button
          onclick="window.print()"
          class="hover:text-white text-text-muted transition-colors uppercase"
        >
          [print]
        </button>
      </div>
    </div>

    <!-- Resume Content -->
    <div class="resume-page mx-auto max-w-md px-4 py-16 font-mono text-xs text-text leading-relaxed">

      <!-- Header -->
      <header class="mb-12 pb-6 border-b border-border/40 text-center">
        <h1 class="text-sm font-semibold tracking-widest text-white uppercase mb-2">
          damilare osibanjo
        </h1>
        <p class="text-text-muted lowercase mb-4">full stack systems developer &amp; web programmer</p>
        <div class="flex flex-col gap-1 text-[10px] text-text-muted lowercase">
          <a href="mailto:dami@varityweb.com" class="hover:text-white transition-colors">
            dami@varityweb.com
          </a>
          <a href="https://github.com/dev-dami" target="_blank" class="hover:text-white transition-colors">
            github.com/dev-dami
          </a>
          <a href="https://www.linkedin.com/in/damilare-osibanjo/" target="_blank" class="hover:text-white transition-colors">
            linkedin.com/in/damilare-osibanjo
          </a>
        </div>
      </header>

      <!-- Summary -->
      <section class="mb-12">
        <h2 class="text-[10px] uppercase text-white tracking-widest mb-4">// summary</h2>
        <p class="text-text-muted lowercase">
          full-stack systems developer and web programmer with 5+ years of experience engineering
          across the entire software stack — from bare-metal x86 kernel development and compilers to
          high-performance web applications and distributed APIs. specialized in typescript, rust,
          go, and c. focused on mechanical sympathy, compile-time correctness, and low-latency systems.
        </p>
      </section>

      <!-- Projects / Work -->
      <section class="mb-12">
        <h2 class="text-[10px] uppercase text-white tracking-widest mb-4">// selected projects</h2>
        <div class="space-y-6">

          <div class="space-y-1">
            <div class="flex items-start justify-between flex-wrap gap-1">
              <span class="text-white">karion_os</span>
              <span class="text-text-muted">rust · x86 · 2024</span>
            </div>
            <p class="text-text-muted">
              bare-metal x86 operating system kernel written in rust. features a custom virtual
              file system (vfs), pre-emptive scheduler, memory manager, keyboard driver, and interrupt
              service routines. ported from c to rust, utilizing the borrow checker to mathematically
              guarantee data-race freedom in kernel space.
            </p>
          </div>

          <div class="space-y-1">
            <div class="flex items-start justify-between flex-wrap gap-1">
              <span class="text-white">track</span>
              <span class="text-text-muted">rust · compiler · 2025</span>
            </div>
            <p class="text-text-muted">
              deterministic systems programming language compiler targeting llvm 22. features linear
              ownership, compile-time borrow checking, and zero-cost abstractions, designed for
              firmware and real-time dsp systems.
            </p>
          </div>

          <div class="space-y-1">
            <div class="flex items-start justify-between flex-wrap gap-1">
              <span class="text-white">gnn-recommender</span>
              <span class="text-text-muted">python · pytorch · 2025</span>
            </div>
            <p class="text-text-muted">
              graph neural network-based recommendation system built from scratch in pytorch. implements
              lightgcn (sparse matrix propagation), bpr loss, and 9 advanced algorithms (self-supervised
              contrastive learning, ultragcn, temporal gating, knowledge graphs, and multi-gpu distributed training).
            </p>
          </div>

          <div class="space-y-1">
            <div class="flex items-start justify-between flex-wrap gap-1">
              <span class="text-white">carv</span>
              <span class="text-text-muted">go · compiler · 2024</span>
            </div>
            <p class="text-text-muted">
              statically-typed systems language compiler built in go that targets optimized c. employs
              a recursive descent parser, ast validation, type checking, compile-time move semantics,
              linear types, lexical lenses, and coroutines.
            </p>
          </div>

          <div class="space-y-1">
            <div class="flex items-start justify-between flex-wrap gap-1">
              <span class="text-white">ignite</span>
              <span class="text-text-muted">rust · virtualization · 2024-2025</span>
            </div>
            <p class="text-text-muted">
              hardware-isolated microvm sandboxing runtime built in rust. leverages linux kvm (via firecracker)
              and apple's virtualization.framework to isolate untrusted js/ts code. uses read-only virtual
              block devices and vsock multiplexing for sub-millisecond vm lifecycle transitions.
            </p>
          </div>

        </div>
      </section>

      <!-- Skills -->
      <section class="mb-12 border-t border-border/40 pt-8">
        <h2 class="text-[10px] uppercase text-white tracking-widest mb-4">// skills</h2>
        <div class="space-y-2 text-text-muted">
          <div>
            <span class="text-white">languages:</span> typescript, javascript, rust, go, c, assembly (x86/arm), python, lua, zig
          </div>
          <div>
            <span class="text-white">web & rts:</span> react, next.js, astro, tailwindcss, html5, css3, webassembly, bun, node.js
          </div>
          <div>
            <span class="text-white">systems & virtual:</span> kvm, firecracker, virtualization.framework, linux, docker, kubernetes, git
          </div>
          <div>
            <span class="text-white">ai/ml:</span> pytorch, tensorboard, graph neural networks (gnns), contrastive learning
          </div>
          <div>
            <span class="text-white">databases:</span> postgresql, redis, mongodb, custom block filesystems
          </div>
        </div>
      </section>

      <!-- Education -->
      <section class="border-t border-border/40 pt-8">
        <h2 class="text-[10px] uppercase text-white tracking-widest mb-4">// education</h2>
        <div>
          <div class="flex items-start justify-between flex-wrap gap-1">
            <span class="text-white">Self-directed learning</span>
            <span class="text-text-muted">2019 – present</span>
          </div>
          <p class="text-text-muted mt-1 leading-relaxed">
            Open source contributions, systems experiments, and compiler development.
            Built working OS kernel, compiler, and distributed tooling from scratch.
          </p>
        </div>
      </section>

    </div>

  </body>
</html>

<style>
  /* ── Print styles ─────────────────────────────── */
  @media print {
    @page {
      margin: 1.5cm 2cm;
      size: A4;
    }

    .no-print {
      display: none !important;
    }

    body {
      background: #fff !important;
      color: #111 !important;
      background-image: none !important;
    }

    body::after {
      display: none !important;
    }

    .resume-page {
      max-width: 100% !important;
      padding: 0 !important;
    }

    a {
      color: #111 !important;
      text-decoration: none !important;
    }

    h1 {
      color: #111 !important;
    }

    h2.resume-section-heading {
      color: #4b5563 !important;
      border-bottom-color: #d1d5db !important;
    }

    .text-white,
    .text-text,
    .text-text-muted,
    .text-muted {
      color: #333 !important;
    }

    .text-accent {
      color: #4b5563 !important;
    }

    .border-border {
      border-color: #e5e7eb !important;
    }

    .resume-entry {
      border-left-color: #d1d5db !important;
    }

    .border-accent\/40 {
      border-color: #4b5563 !important;
    }
  }
</style>
