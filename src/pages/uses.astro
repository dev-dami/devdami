---
import Layout from "../layouts/Layout.astro";

const pageTitle = "/uses — Damilare Osibanjo";
const pageDescription = "My development setup: hardware specs, editor config, terminal stack, programming languages, and tooling I use daily.";
const pageUrl = "https://devdami.varityweb.com/uses";
---

<Layout title={pageTitle} description={pageDescription} canonical={pageUrl}>
  <div class="mx-auto max-w-blog space-y-10">

    <header class="mb-4">
      <p class="text-xs font-mono text-accent tracking-widest uppercase mb-2">/uses</p>
      <h1 class="text-2xl md:text-3xl font-semibold text-text-dark leading-tight">
        Development Setup
      </h1>
      <p class="mt-3 text-sm text-muted leading-relaxed">
        Hardware, editor, terminal, languages, and tools I reach for every day.
        Inspired by <a href="https://uses.tech" class="text-accent hover:underline" target="_blank" rel="noopener">uses.tech</a>.
      </p>
    </header>

    <!-- Hardware -->
    <section class="border border-border rounded-lg p-6 md:p-8 bg-surface/20">
      <h2 class="text-base font-semibold text-text-dark font-mono mb-4 flex items-center gap-2">
        <span class="text-accent">$</span> Hardware
      </h2>
      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <h3 class="text-xs font-mono text-accent tracking-wider mb-2">Machine</h3>
          <ul class="space-y-1.5 text-sm text-text">
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span>HP Laptop 15-da0xxx</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span>Intel Core i3-8130U @ 2.20GHz (4 cores)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span>8GB RAM</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span>Intel UHD Graphics 620</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span>~900GB SSD</span>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-xs font-mono text-accent tracking-wider mb-2">Peripherals</h3>
          <ul class="space-y-1.5 text-sm text-text">
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span>Firefox (daily driver browser)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span>VS Code 1.117 (occasional frontend work)</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- OS & Desktop -->
    <section class="border border-border rounded-lg p-6 md:p-8 bg-surface/20">
      <h2 class="text-base font-semibold text-text-dark font-mono mb-4 flex items-center gap-2">
        <span class="text-accent">$</span> OS &amp; Desktop
      </h2>
      <ul class="space-y-1.5 text-sm text-text">
        <li class="flex items-start gap-2">
          <span class="text-muted/40 mt-1">—</span>
          <span><strong class="text-text-dark">OS:</strong> EndeavourOS (Arch Linux)</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-muted/40 mt-1">—</span>
          <span><strong class="text-text-dark">Kernel:</strong> Linux 7.0.9-arch1-1</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-muted/40 mt-1">—</span>
          <span><strong class="text-text-dark">DE:</strong> KDE Plasma</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-muted/40 mt-1">—</span>
          <span><strong class="text-text-dark">Shell:</strong> Fish with Starship prompt</span>
        </li>
      </ul>
    </section>

    <!-- Editor & Terminal -->
    <section class="border border-border rounded-lg p-6 md:p-8 bg-surface/20">
      <h2 class="text-base font-semibold text-text-dark font-mono mb-4 flex items-center gap-2">
        <span class="text-accent">$</span> Editor &amp; Terminal
      </h2>
      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <h3 class="text-xs font-mono text-accent tracking-wider mb-2">Neovim 0.12.2</h3>
          <ul class="space-y-1.5 text-sm text-text">
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span>tokyonight.nvim (theme)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span>Telescope.nvim (fuzzy finder)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span>nvim-cmp (autocompletion)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span>Harpoon (quick navigation)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span>nvim-tree (file explorer)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span>lualine.nvim (statusline)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span>vim-fugitive (Git integration)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span>undotree (undo history)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span>nvim-autopairs</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span>presence.nvim (Discord Rich Presence)</span>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-xs font-mono text-accent tracking-wider mb-2">Terminal &amp; Multiplexer</h3>
          <ul class="space-y-1.5 text-sm text-text">
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span><strong class="text-text-dark">Terminal:</strong> Alacritty (Dracula theme)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span><strong class="text-text-dark">Multiplexer:</strong> tmux 3.6b</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span><strong class="text-text-dark">Prompt:</strong> Starship</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted/40 mt-1">—</span>
              <span><strong class="text-text-dark">Font:</strong> Hack Nerd Font Mono</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Languages & Runtimes -->
    <section class="border border-border rounded-lg p-6 md:p-8 bg-surface/20">
      <h2 class="text-base font-semibold text-text-dark font-mono mb-4 flex items-center gap-2">
        <span class="text-accent">$</span> Languages &amp; Runtimes
      </h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <div class="border border-border rounded p-4">
          <div class="text-xs font-mono text-accent mb-1">Rust</div>
          <div class="text-xs text-muted">rustc 1.95.0 / cargo 1.95.0</div>
        </div>
        <div class="border border-border rounded p-4">
          <div class="text-xs font-mono text-accent mb-1">Go</div>
          <div class="text-xs text-muted">go 1.26.3</div>
        </div>
        <div class="border border-border rounded p-4">
          <div class="text-xs font-mono text-accent mb-1">Zig</div>
          <div class="text-xs text-muted">zig 0.16.0</div>
        </div>
        <div class="border border-border rounded p-4">
          <div class="text-xs font-mono text-accent mb-1">TypeScript</div>
          <div class="text-xs text-muted">ts 6.0.2 / Node 24.14.0</div>
        </div>
        <div class="border border-border rounded p-4">
          <div class="text-xs font-mono text-accent mb-1">Bun</div>
          <div class="text-xs text-muted">bun 1.3.14</div>
        </div>
        <div class="border border-border rounded p-4">
          <div class="text-xs font-mono text-accent mb-1">npm</div>
          <div class="text-xs text-muted">npm 11.9.0</div>
        </div>
        <div class="border border-border rounded p-4">
          <div class="text-xs font-mono text-accent mb-1">PHP</div>
          <div class="text-xs text-muted">php-cs-fixer (occasional)</div>
        </div>
        <div class="border border-border rounded p-4">
          <div class="text-xs font-mono text-accent mb-1">Python</div>
          <div class="text-xs text-muted">pyright LSP</div>
        </div>
      </div>
    </section>

    <!-- Key Configs -->
    <section class="border border-border rounded-lg p-6 md:p-8 bg-surface/20">
      <h2 class="text-base font-semibold text-text-dark font-mono mb-4 flex items-center gap-2">
        <span class="text-accent">$</span> Key Config Notes
      </h2>
      <ul class="space-y-2 text-sm text-text">
        <li class="flex items-start gap-2">
          <span class="text-muted/40 mt-1">—</span>
          <span>Leader key: <kbd class="px-1.5 py-0.5 bg-border/30 rounded text-xs font-mono">Space</kbd></span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-muted/40 mt-1">—</span>
          <span>Relative line numbers, 4-space tabs, colorcolumn at 80</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-muted/40 mt-1">—</span>
          <span>Clipboard synced with system (<code class="text-accent text-xs">unnamedplus</code>)</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-muted/40 mt-1">—</span>
          <span>Undo history persisted to <code class="text-accent text-xs">~/.vim/undodir</code></span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-muted/40 mt-1">—</span>
          <span>Starship prompt with directory, Git branch, language version info, and timestamp</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-muted/40 mt-1">—</span>
          <span>Fish shell with <code class="text-accent text-xs">~/.local/bin</code>, <code class="text-accent text-xs">~/.opencode/bin</code>, and <code class="text-accent text-xs">~/.bun/bin</code> in PATH</span>
        </li>
      </ul>
    </section>

    <!-- Editor keybinds visualization -->
    <section class="border border-border rounded-lg p-6 md:p-8 bg-surface/20">
      <h2 class="text-base font-semibold text-text-dark font-mono mb-4 flex items-center gap-2">
        <span class="text-accent">$</span> Editor Shortcuts
      </h2>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="text-xs">
          <span class="text-muted/60">Space+cd</span>
          <span class="text-muted ml-2">→ Open file in tree</span>
        </div>
        <div class="text-xs">
          <span class="text-muted/60">Space+p</span>
          <span class="text-muted ml-2">→ Paste without replacing clipboard</span>
        </div>
        <div class="text-xs">
          <span class="text-muted/60">Space+d</span>
          <span class="text-muted ml-2">→ Delete to black hole register</span>
        </div>
        <div class="text-xs">
          <span class="text-muted/60">Space+s</span>
          <span class="text-muted ml-2">→ Substitute word under cursor</span>
        </div>
        <div class="text-xs">
          <span class="text-muted/60">Space+x</span>
          <span class="text-muted ml-2">→ Make file executable</span>
        </div>
        <div class="text-xs">
          <span class="text-muted/60">Space+cc</span>
          <span class="text-muted ml-2">→ php-cs-fixer on current file</span>
        </div>
        <div class="text-xs">
          <span class="text-muted/60">Ctrl+j/k</span>
          <span class="text-muted ml-2">→ Quickfix list navigation</span>
        </div>
        <div class="text-xs">
          <span class="text-muted/60">Ctrl+d/u</span>
          <span class="text-muted ml-2">→ Page up/down (cursor centered)</span>
        </div>
      </div>
    </section>

    <!-- Global npm tools -->
    <section class="border border-border rounded-lg p-6 md:p-8 bg-surface/20">
      <h2 class="text-base font-semibold text-text-dark font-mono mb-4 flex items-center gap-2">
        <span class="text-accent">$</span> Global Tools
      </h2>
      <ul class="space-y-1.5 text-sm text-text">
        <li class="flex items-start gap-2">
          <span class="text-muted/40 mt-1">—</span>
          <span>eslint_d 15.0.2</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-muted/40 mt-1">—</span>
          <span>pyright 1.1.408</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-muted/40 mt-1">—</span>
          <span>typescript-language-server 5.1.3</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-muted/40 mt-1">—</span>
          <span>OhMyOpenCode (Sisyphus AI agent)</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-muted/40 mt-1">—</span>
          <span>Next.js, Astro (static site generation)</span>
        </li>
      </ul>
    </section>

    <!-- Footer note -->
    <p class="text-xs text-muted/60 font-mono text-center pt-4">
      Last updated May 2026
    </p>

  </div>
</Layout>
