---
import Layout from "../layouts/Layout.astro";
import ToolIcon from "../components/ToolIcon";
export const prerender = true;

const pageTitle = "/uses — Damilare Osibanjo";
const pageDescription = "My development setup: hardware specs, editor config, terminal stack, programming languages, and tooling I use daily.";
const pageUrl = "https://devdami.varityweb.com/uses";
---

<Layout title={pageTitle} description={pageDescription} canonical={pageUrl}>
  <div class="max-w-xl mx-auto py-16 font-mono text-xs text-text leading-relaxed">
    <header class="mb-12 text-center">
      <a href="/" class="text-text-muted hover:text-white transition-all duration-150 block mb-4">&lt;- home</a>
      <h1 class="text-sm font-semibold tracking-widest text-white uppercase mb-2">/uses</h1>
      <p class="text-text-muted lowercase">
        development setup: hardware, editor, shell, languages & tools
      </p>
    </header>

    <div class="space-y-6">
      <!-- Hardware -->
      <section class="bg-surface/30 border border-border/40 hover:border-accent/40 rounded-lg p-5 transition-all duration-500 ease-out space-y-4">
        <h2 class="text-[10px] uppercase text-white tracking-widest">// hardware</h2>
        <div class="space-y-4">
          <div>
            <span class="text-white lowercase block mb-1.5">machine:</span>
            <ul class="space-y-1.5 pl-2">
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="machine" />
                <span>HP Laptop 15-da0xxx</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="cpu" />
                <span>Intel Core i3-8130U @ 2.20GHz (4 cores)</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="ram" />
                <span>8GB RAM</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="gpu" />
                <span>Intel UHD Graphics 620</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="ssd" />
                <span>~900GB SSD</span>
              </li>
            </ul>
          </div>
          <div>
            <span class="text-white lowercase block mb-1.5">peripherals & browser:</span>
            <ul class="space-y-1.5 pl-2">
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="firefox" />
                <span>Firefox (daily driver browser)</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="keyboard" />
                <span>Generic mechanical keyboard (Cherry MX Blue)</span>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <!-- OS & Desktop -->
      <section class="bg-surface/30 border border-border/40 hover:border-accent/40 rounded-lg p-5 transition-all duration-500 ease-out space-y-4">
        <h2 class="text-[10px] uppercase text-white tracking-widest">// os & environment</h2>
        <ul class="space-y-1.5 pl-2">
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="endeavouros" />
            <span>OS: EndeavourOS (Arch Linux)</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="linux" />
            <span>Kernel: Linux 7.0.9-arch1-1</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="kde" />
            <span>DE: KDE Plasma 6</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="fish" />
            <span>Shell: Fish with Starship prompt</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="kwin" />
            <span>WM/DE: KWin</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="yay" />
            <span>AUR Helper: yay</span>
          </li>
        </ul>
      </section>

      <!-- Editor & Terminal -->
      <section class="bg-surface/30 border border-border/40 hover:border-accent/40 rounded-lg p-5 transition-all duration-500 ease-out space-y-4">
        <h2 class="text-[10px] uppercase text-white tracking-widest">// editor & terminal</h2>
        <div class="space-y-4">
          <div>
            <span class="text-white lowercase block mb-1.5">neovim (daily driver):</span>
            <ul class="space-y-1.5 pl-2">
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="tokyonight" />
                <span>tokyonight.nvim (theme)</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="telescope" />
                <span>Telescope.nvim (fuzzy finder)</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="cmp" />
                <span>nvim-cmp (autocompletion)</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="harpoon" />
                <span>Harpoon (quick navigation)</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="tree" />
                <span>nvim-tree (file explorer)</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="lualine" />
                <span>lualine.nvim (statusline)</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="fugitive" />
                <span>vim-fugitive (Git integration)</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="undotree" />
                <span>undotree (undo history)</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="autopairs" />
                <span>nvim-autopairs</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="comment" />
                <span>comment.nvim</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="treesitter" />
                <span>nvim-treesitter (syntax tree)</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="lsp" />
                <span>lsp-zero.nvim (LSP management)</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="discord" />
                <span>presence.nvim (Discord RPC)</span>
              </li>
            </ul>
          </div>
          <div>
            <span class="text-white lowercase block mb-1.5">terminal:</span>
            <ul class="space-y-1.5 pl-2">
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="alacritty" />
                <span>Terminal: Alacritty (Dracula theme)</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="tmux" />
                <span>Multiplexer: tmux 3.6b</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="font" />
                <span>Font: Hack Nerd Font Mono</span>
              </li>
              <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
                <ToolIcon name="yazi" />
                <span>File Manager: yazi (TUI)</span>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Languages & Runtimes -->
      <section class="bg-surface/30 border border-border/40 hover:border-accent/40 rounded-lg p-5 transition-all duration-500 ease-out space-y-4">
        <h2 class="text-[10px] uppercase text-white tracking-widest">// languages & runtimes</h2>
        <ul class="space-y-1.5 pl-2">
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="rust" />
            <span>Rust (rustc 1.95.0 / cargo 1.95.0)</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="go" />
            <span>Go (go 1.26.3)</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="zig" />
            <span>Zig (zig 0.16.0)</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="typescript" />
            <span>TypeScript (ts 6.0.2 / Node 24.14.0)</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="bun" />
            <span>Bun (bun 1.3.14)</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="python" />
            <span>Python (pyright LSP)</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="c" />
            <span>C (gcc 14 / clang 19)</span>
          </li>
        </ul>
      </section>

      <!-- CLI Tools -->
      <section class="bg-surface/30 border border-border/40 hover:border-accent/40 rounded-lg p-5 transition-all duration-500 ease-out space-y-4">
        <h2 class="text-[10px] uppercase text-white tracking-widest">// cli tools</h2>
        <ul class="space-y-1.5 pl-2">
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="git" />
            <span>git & lazygit</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="docker" />
            <span>docker & compose</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="ripgrep" />
            <span>ripgrep (rg)</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="fd" />
            <span>fd</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="fzf" />
            <span>fzf</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="bat" />
            <span>bat</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="eza" />
            <span>eza</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="btop" />
            <span>btop</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="jq" />
            <span>jq</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="zoxide" />
            <span>zoxide (z)</span>
          </li>
        </ul>
      </section>

      <!-- Key Configs -->
      <section class="bg-surface/30 border border-border/40 hover:border-accent/40 rounded-lg p-5 transition-all duration-500 ease-out space-y-4">
        <h2 class="text-[10px] uppercase text-white tracking-widest">// configurations</h2>
        <ul class="space-y-1.5 pl-2">
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="lsp" />
            <span>Leader key: space</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="font" />
            <span>Relative line numbers, 4-space tabs</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="telescope" />
            <span>space+ff: Telescope find files</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="ripgrep" />
            <span>space+fw: Telescope live grep</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="tree" />
            <span>space+e: Toggle file explorer</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="harpoon" />
            <span>space+h: Harpoon quick menu</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="tmux" />
            <span>Ctrl+s / Ctrl+b: tmux prefix</span>
          </li>
          <li class="group flex items-center gap-2.5 py-0.5 text-text-muted hover:text-white transition-colors duration-200">
            <ToolIcon name="alacritty" />
            <span>ll: eza -la, cat: bat, grep: rg</span>
          </li>
        </ul>
      </section>
    </div>
  </div>
</Layout>
