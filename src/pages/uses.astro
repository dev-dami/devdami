---
import Layout from "../layouts/Layout.astro";
import ToolIcon from "../components/ToolIcon";
import ToolBadge from "../components/ToolBadge.astro";
export const prerender = true;

const pageTitle = "/uses — Damilare Osibanjo";
const pageDescription = "My development setup: hardware specs, editor config, terminal stack, programming languages, and tooling I use daily.";
const pageUrl = "https://devdami.varityweb.com/uses";
---

<Layout title={pageTitle} description={pageDescription} canonical={pageUrl}>
  <div class="max-w-md mx-auto py-16 font-mono text-xs text-text leading-relaxed">
    <header class="mb-12 text-center">
      <a href="/" class="text-text-muted hover:text-white transition-colors block mb-4">&lt;- home</a>
      <h1 class="text-sm font-semibold tracking-widest text-white uppercase mb-2">/uses</h1>
      <p class="text-text-muted lowercase">
        development setup: hardware, editor, shell, languages & tools
      </p>
    </header>

    <!-- Hardware -->
    <section class="mb-12 space-y-4">
      <h2 class="text-[10px] uppercase text-white tracking-widest">// hardware</h2>
      <div class="space-y-4">
        <div>
          <span class="text-white">machine:</span>
          <ul class="space-y-1 pl-4 mt-1 text-text-muted">
            <li>- HP Laptop 15-da0xxx</li>
            <li>- Intel Core i3-8130U @ 2.20GHz (4 cores)</li>
            <li>- 8GB RAM</li>
            <li>- Intel UHD Graphics 620</li>
            <li>- ~900GB SSD</li>
          </ul>
        </div>
        <div>
          <span class="text-white">peripherals & browser:</span>
          <ul class="space-y-1 pl-4 mt-1 text-text-muted">
            <li>- Firefox (daily driver browser)</li>
            <li>- Generic mechanical keyboard (Cherry MX Blue)</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- OS & Desktop -->
    <section class="mb-12 space-y-4 border-t border-border/40 pt-8">
      <h2 class="text-[10px] uppercase text-white tracking-widest">// os & environment</h2>
      <ul class="space-y-1 pl-4 text-text-muted">
        <li>- OS: EndeavourOS (Arch Linux)</li>
        <li>- Kernel: Linux 7.0.9-arch1-1</li>
        <li>- DE: KDE Plasma 6</li>
        <li>- Shell: Fish with Starship prompt</li>
        <li>- WM/DE: KWin</li>
        <li>- AUR Helper: yay</li>
      </ul>
    </section>

    <!-- Editor & Terminal -->
    <section class="mb-12 space-y-4 border-t border-border/40 pt-8">
      <h2 class="text-[10px] uppercase text-white tracking-widest">// editor & terminal</h2>
      <div class="space-y-4">
        <div>
          <span class="text-white">neovim (daily driver):</span>
          <ul class="space-y-1 pl-4 mt-1 text-text-muted">
            <li>- tokyonight.nvim (theme)</li>
            <li>- Telescope.nvim (fuzzy finder)</li>
            <li>- nvim-cmp (autocompletion)</li>
            <li>- Harpoon (quick navigation)</li>
            <li>- nvim-tree (file explorer)</li>
            <li>- lualine.nvim (statusline)</li>
            <li>- vim-fugitive (Git integration)</li>
            <li>- undotree (undo history)</li>
            <li>- nvim-autopairs</li>
            <li>- comment.nvim</li>
            <li>- nvim-treesitter (syntax tree)</li>
            <li>- lsp-zero.nvim (LSP management)</li>
            <li>- presence.nvim (Discord RPC)</li>
          </ul>
        </div>
        <div>
          <span class="text-white">terminal:</span>
          <ul class="space-y-1 pl-4 mt-1 text-text-muted">
            <li>- Terminal: Alacritty (Dracula theme)</li>
            <li>- Multiplexer: tmux 3.6b</li>
            <li>- Font: Hack Nerd Font Mono</li>
            <li>- File Manager: yazi (TUI)</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Languages & Runtimes -->
    <section class="mb-12 space-y-4 border-t border-border/40 pt-8">
      <h2 class="text-[10px] uppercase text-white tracking-widest">// languages & runtimes</h2>
      <ul class="space-y-1 pl-4 text-text-muted">
        <li>- Rust (rustc 1.95.0 / cargo 1.95.0)</li>
        <li>- Go (go 1.26.3)</li>
        <li>- Zig (zig 0.16.0)</li>
        <li>- TypeScript (ts 6.0.2 / Node 24.14.0)</li>
        <li>- Bun (bun 1.3.14)</li>
        <li>- Python (pyright LSP)</li>
        <li>- C (gcc 14 / clang 19)</li>
      </ul>
    </section>

    <!-- CLI Tools -->
    <section class="mb-12 space-y-4 border-t border-border/40 pt-8">
      <h2 class="text-[10px] uppercase text-white tracking-widest">// cli tools</h2>
      <ul class="space-y-1 pl-4 text-text-muted">
        <li>- git & lazygit</li>
        <li>- docker & compose</li>
        <li>- ripgrep (rg)</li>
        <li>- fd</li>
        <li>- fzf</li>
        <li>- bat</li>
        <li>- eza</li>
        <li>- btop</li>
        <li>- jq</li>
        <li>- zoxide (z)</li>
      </ul>
    </section>

    <!-- Key Configs -->
    <section class="space-y-4 border-t border-border/40 pt-8">
      <h2 class="text-[10px] uppercase text-white tracking-widest">// configurations</h2>
      <ul class="space-y-1 pl-4 text-text-muted font-mono">
        <li>- Leader key: space</li>
        <li>- Relative line numbers, 4-space tabs</li>
        <li>- space+ff: Telescope find files</li>
        <li>- space+fw: Telescope live grep</li>
        <li>- space+e: Toggle file explorer</li>
        <li>- space+h: Harpoon quick menu</li>
        <li>- Ctrl+s / Ctrl+b: tmux prefix</li>
        <li>- ll: eza -la, cat: bat, grep: rg</li>
      </ul>
    </section>
  </div>
</Layout>

