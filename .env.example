# Resend API Key for contact form
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address — MUST use a domain verified in your Resend dashboard.
# The default onboarding@resend.dev can ONLY send to your Resend registration email.
# Once you verify a domain (e.g. varityweb.com), set this to:
#   Portfolio Contact <noreply@varityweb.com>
CONTACT_EMAIL_FROM=Portfolio Contact <noreply@varityweb.com>

# Where contact form submissions are delivered
CONTACT_EMAIL_TO=dami@varityweb.com
